<?xml version="1.0" encoding="UTF-8"?>
<!-- A SMILE schema file © Astronomical Observatory, Ghent University -->
<smile-schema type="Schema" format="1.2" producer="SKIRT v9.0 (git 5259971 built on 18/08/2025 at 15:43:12)" time="2026-04-18T16:05:07.491">
    <Schema name="SKIRT" title="a SKIRT parameter file" version="v9.0" extension="ski" root="skirt-simulation-hierarchy" type="MonteCarloSimulation" format="9" url="http://www.skirt.ugent.be/skirt9">
        <types type="Type">
            <!--Non-concrete types, in alphabetical order-->
            <Type name="AllSkyProjection" base="SimulationItem" title="an all-sky projection"/>
            <Type name="AngularDistribution" base="SimulationItem" title="an angular emission profile"/>
            <Type name="AxAngularDistribution" base="AngularDistribution" title="an axisymmetric angular emission profile" insert="Dimension2">
                <properties type="Property">
                    <DoubleProperty name="symmetryX" title="the direction of the positive symmetry axis, x component" insert="symmetryX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryY" title="the direction of the positive symmetry axis, y component" insert="symmetryY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryZ" title="the direction of the positive symmetry axis, z component" default="1" quantity="length"/>
                </properties>
            </Type>
            <Type name="AxGeometry" base="Geometry" title="an axisymmetric geometry" insert="Dimension2"/>
            <Type name="AxisMaterialNormalization" base="MaterialNormalization" title="normalization by defining some quantity along a coordinate axis">
                <properties type="Property">
                    <EnumProperty name="axis" title="the axis along which to specify the normalization" default="Z">
                        <enumValues type="EnumValue">
                            <EnumValue name="X" title="the X axis of the model coordinate sytem"/>
                            <EnumValue name="Y" title="the Y axis of the model coordinate sytem"/>
                            <EnumValue name="Z" title="the Z axis of the model coordinate sytem"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="Band" base="SimulationItem" title="a wavelength band (transmission curve)"/>
            <Type name="BandWavelengthGrid" base="WavelengthGrid" title="a wavelength grid defined by a list of (broad)bands"/>
            <Type name="BoxSpatialGrid" base="SpatialGrid" title="a spatial grid bounded by a box">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the box in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the box in the Z direction" quantity="length"/>
                </properties>
            </Type>
            <Type name="CenteredSource" base="SpecialtySource" title="a centered primary source" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="centerX" title="the center of the source, x component" insert="centerX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="centerY" title="the center of the source, y component" insert="centerY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="centerZ" title="the center of the source, z component" insert="centerZ:Dimension2" default="0" quantity="length"/>
                </properties>
            </Type>
            <Type name="ClipGeometryDecorator" base="Geometry" title="a decorator that clips another geometry" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry to be clipped" base="Geometry"/>
                    <EnumProperty name="remove" title="the region to be removed">
                        <enumValues type="EnumValue">
                            <EnumValue name="Inside" title="the inner region (creating a cavity)"/>
                            <EnumValue name="Outside" title="the outer region (cropping)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="ContSED" base="SED" title="a continuous spectral energy distribution"/>
            <Type name="Cosmology" base="SimulationItem" title="a set of cosmology parameters, including redshift"/>
            <Type name="CylinderSpatialGrid" base="SpatialGrid" title="a spatial grid bounded by a cylinder">
                <properties type="Property">
                    <DoubleProperty name="minRadius" title="the inner cylindrical radius of the grid" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the outer cylindrical radius of the grid" min="]0" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the cylinder in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the cylinder in the Z direction" quantity="length"/>
                </properties>
            </Type>
            <Type name="DisjointWavelengthGrid" base="WavelengthGrid" title="a wavelength grid with non-overlapping bins"/>
            <Type name="DistantInstrument" base="Instrument" title="a distant instrument">
                <properties type="Property">
                    <DoubleProperty name="distance" title="the distance to the system" min="[0" quantity="distance"/>
                    <DoubleProperty name="inclination" title="the inclination angle θ of the detector" displayedIf="Dimension2|Dimension3" default="0 deg" min="0 deg" max="180 deg" quantity="posangle"/>
                    <DoubleProperty name="azimuth" title="the azimuth angle φ of the detector" displayedIf="Dimension3" default="0 deg" min="-360 deg" max="360 deg" quantity="posangle"/>
                    <DoubleProperty name="roll" title="the roll angle ω of the detector" displayedIf="Level2&amp;(Dimension2|Dimension3)" default="0 deg" min="-360 deg" max="360 deg" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="DustDestructionRecipe" base="DynamicStateRecipe" title="a dust destruction recipe">
                <properties type="Property">
                    <DoubleProperty name="densityFractionTolerance" title="the convergence tolerance on the dynamic density fraction" default="0.05" min="[1e-6" max="0.5]"/>
                </properties>
            </Type>
            <Type name="DustMix" base="MaterialMix" title="a dust mix"/>
            <Type name="DynamicStateRecipe" base="SimulationItem" title="a dynamic medium state recipe">
                <properties type="Property">
                    <IntProperty name="maxNotConvergedCells" title="the number of spatial cells allowed to not converge" default="0" min="0"/>
                </properties>
            </Type>
            <Type name="EmittingGasMix" base="MaterialMix" title="an emitting gas mix" insert="GasMix">
                <properties type="Property">
                    <DoubleProperty name="sourceWeight" title="the weight of this secondary source for the number of photon packets launched" displayedIf="Level3" default="1" min="]0" max="1000]"/>
                    <DoubleProperty name="wavelengthBias" title="the fraction of secondary photon packet wavelengths sampled from a bias distribution" displayedIf="Level3" default="0.5" min="[0" max="1]"/>
                    <ItemProperty name="wavelengthBiasDistribution" title="the bias distribution for sampling secondary photon packet wavelengths" relevantIf="wavelengthBias" displayedIf="Level3" default="DefaultWavelengthDistribution" base="WavelengthDistribution"/>
                </properties>
            </Type>
            <Type name="FamilySED" base="ContSED" title="a spectral energy distribution obtained from an SED family"/>
            <Type name="Form" base="SimulationItem" title="a probe form"/>
            <Type name="GenGeometry" base="Geometry" title="a geometry without a specific symmetry" insert="Dimension3"/>
            <Type name="GenericForm" base="Form" title="a generic probe form"/>
            <Type name="Geometry" base="SimulationItem" title="a geometry"/>
            <Type name="GrainComposition" base="SimulationItem" title="a dust grain composition"/>
            <Type name="GrainSizeDistribution" base="SimulationItem" title="a dust grain size distribution"/>
            <Type name="ImportedGeometry" base="GenGeometry" title="a geometry imported from snapshot data" subPropertyIndex="1" insert="SiteListInterface">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file to be imported"/>
                    <BoolProperty name="importMetallicity" title="import a metallicity column" default="false"/>
                    <BoolProperty name="importTemperature" title="import a temperature column" default="false"/>
                    <DoubleProperty name="maxTemperature" title="the maximum temperature for included mass (or zero to include all)" relevantIf="importTemperature" default="0 K" min="[0 K" max="1000000 K]" quantity="temperature"/>
                    <StringProperty name="useColumns" title="a list of names corresponding to columns in the file to be imported" displayedIf="Level3" requiredIf="false"/>
                </properties>
            </Type>
            <Type name="ImportedMedium" base="Medium" title="a transfer medium imported from snapshot data" subPropertyIndex="1" insert="Dimension3,SiteListInterface">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file to be imported"/>
                    <DoubleProperty name="massFraction" title="the fraction of the mass to be included (or one to include all)" default="1" min="[0" max="1]"/>
                    <BoolProperty name="importMetallicity" title="import a metallicity column" default="false"/>
                    <BoolProperty name="importTemperature" title="import a temperature column" default="false"/>
                    <DoubleProperty name="maxTemperature" title="the maximum temperature for included mass (or zero to include all)" relevantIf="importTemperature" default="0 K" min="[0 K" max="1000000 K]" quantity="temperature"/>
                    <BoolProperty name="importVelocity" title="import velocity components (3 columns)" relevantIf="Panchromatic" displayedIf="Level2" insert="importVelocity:MediumVelocity" default="false"/>
                    <BoolProperty name="importMagneticField" title="import magnetic field components (3 columns)" displayedIf="Level3" insert="importMagneticField:MagneticField" default="false"/>
                    <BoolProperty name="importVariableMixParams" title="import parameter(s) to select a spatially varying material mix" displayedIf="(!NonIdentitySpatialCellLibrary)&amp;Level2" default="false"/>
                    <StringProperty name="useColumns" title="a list of names corresponding to columns in the file to be imported" displayedIf="Level3" requiredIf="false"/>
                    <ItemProperty name="materialMix" title="the material type and properties throughout the medium" relevantIf="!importVariableMixParams" default="MeanInterstellarDustMix" base="MaterialMix"/>
                    <ItemProperty name="materialMixFamily" title="the material mix family addressed by the imported parameter(s)" relevantIf="importVariableMixParams" default="SelectDustMixFamily" base="MaterialMixFamily"/>
                </properties>
            </Type>
            <Type name="ImportedSource" base="Source" title="a primary source imported from snapshot data" subPropertyIndex="1" insert="Dimension3">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file to be imported"/>
                    <BoolProperty name="importVelocity" title="import velocity components (3 columns)" relevantIf="Panchromatic" displayedIf="Level2" insert="importVelocity:SourceVelocity" default="false"/>
                    <BoolProperty name="importVelocityDispersion" title="import velocity dispersion (spherically symmetric)" relevantIf="Panchromatic&amp;importVelocity" displayedIf="Level2" default="false"/>
                    <BoolProperty name="importCurrentMass" title="import current mass" displayedIf="Level3" insert="importCurrentMass:CurrentMass" default="false"/>
                    <BoolProperty name="importBias" title="import a per-particle/cell source bias weight" displayedIf="Level3" default="false"/>
                    <StringProperty name="useColumns" title="a list of names corresponding to columns in the file to be imported" displayedIf="Level3" requiredIf="false"/>
                    <ItemProperty name="sedFamily" title="the SED family for assigning spectra to the imported sources" default="BlackBodySEDFamily" base="SEDFamily"/>
                </properties>
            </Type>
            <Type name="ImportedSourceWeightedProbe" base="InputModelFormProbe" title="an imported source weighted probe" displayedIf="ImportedSource">
                <properties type="Property">
                    <EnumProperty name="weight" title="weight for averaging the probed quantity" default="Luminosity">
                        <enumValues type="EnumValue">
                            <EnumValue name="Luminosity" title="luminosity"/>
                            <EnumValue name="InitialMass" title="initial mass"/>
                            <EnumValue name="CurrentMass" title="current mass"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="wavelength" title="the wavelength at which to determine the luminosity" relevantIf="weightLuminosity" default="0.55 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                </properties>
            </Type>
            <Type name="InputModelFormProbe" base="Probe" title="an input model form probe" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="form" title="the form describing how this quantity should be probed" default="ParallelProjectionForm" base="GenericForm"/>
                </properties>
            </Type>
            <Type name="Instrument" base="SimulationItem" title="an instrument" subPropertyIndex="2">
                <properties type="Property">
                    <StringProperty name="instrumentName" title="the name for this instrument"/>
                    <ItemProperty name="wavelengthGrid" title="the wavelength grid for this instrument" relevantIf="Panchromatic" displayedIf="Level2" requiredIf="!DefaultInstrumentWavelengthGrid" base="WavelengthGrid"/>
                    <BoolProperty name="recordComponents" title="record flux components separately" default="false"/>
                    <IntProperty name="numScatteringLevels" title="the number of individually recorded scattering levels" relevantIf="recordComponents" displayedIf="Level2" default="0" min="0" max="99"/>
                    <BoolProperty name="recordPolarization" title="record polarization (Stokes vector elements)" displayedIf="Level2" default="false"/>
                    <BoolProperty name="recordStatistics" title="record information for calculating statistical properties" displayedIf="Level2" default="false"/>
                </properties>
            </Type>
            <Type name="Item" base="" title="a SMILE item"/>
            <Type name="LineSED" base="SED" title="a spectral energy distribution consisting of discrete lines" allowedIf="Panchromatic" displayedIf="Level2"/>
            <Type name="LuminosityNormalization" base="SimulationItem" title="the luminosity normalization for a primary source"/>
            <Type name="MaterialMix" base="SimulationItem" title="a material mix"/>
            <Type name="MaterialMixFamily" base="SimulationItem" title="a family of material mixes"/>
            <Type name="MaterialNormalization" base="SimulationItem" title="a normalization for the amount of material"/>
            <Type name="Medium" base="SimulationItem" title="a transfer medium"/>
            <Type name="Mesh" base="SimulationItem" title="a mesh">
                <properties type="Property">
                    <IntProperty name="numBins" title="the number of bins in the mesh" default="100" min="1" max="100000"/>
                </properties>
            </Type>
            <Type name="MeshGeometry" base="ImportedGeometry" title="a geometry imported from mesh-based data">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the domain in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the domain in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the domain in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the domain in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the domain in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the domain in the Z direction" quantity="length"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated mass density)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated number density)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MeshMedium" base="ImportedMedium" title="a geometry imported from mesh-based data">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the domain in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the domain in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the domain in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the domain in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the domain in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the domain in the Z direction" quantity="length"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated)"/>
                            <EnumValue name="MassDensityAndMass" title="both mass density and volume-integrated mass"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated)"/>
                            <EnumValue name="NumberDensityAndNumber" title="both number density and volume-integrated number"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MeshSource" base="ImportedSource" title="a primary source imported from mesh-based data">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the domain in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the domain in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the domain in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the domain in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the domain in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the domain in the Z direction" quantity="length"/>
                </properties>
            </Type>
            <Type name="MultiGrainDustMix" base="DustMix" title="a dust mix with one or more grain populations"/>
            <Type name="NormalizedSource" base="Source" title="a primary source with a single SED" subPropertyIndex="0">
                <properties type="Property">
                    <ItemProperty name="sed" title="the spectral energy distribution for the source" default="BlackBodySED" base="SED"/>
                    <ItemProperty name="normalization" title="the type of luminosity normalization for the source" default="IntegratedLuminosityNormalization" base="LuminosityNormalization"/>
                </properties>
            </Type>
            <Type name="PolarizationProfile" base="SimulationItem" title="a polarized emission profile"/>
            <Type name="Probe" base="SimulationItem" title="a probe">
                <properties type="Property">
                    <StringProperty name="probeName" title="the name for this probe"/>
                </properties>
            </Type>
            <Type name="RangeGrainSizeDistribution" base="GrainSizeDistribution" title="a dust grain size distribution with a configurable size range">
                <properties type="Property">
                    <DoubleProperty name="minSize" title="the minimum grain size for this distribution" min="[1 Angstrom" max="1 mm]" quantity="grainsize"/>
                    <DoubleProperty name="maxSize" title="the maximum grain size for this distribution" min="[1 Angstrom" max="1 mm]" quantity="grainsize"/>
                </properties>
            </Type>
            <Type name="RangeWavelengthDistribution" base="WavelengthDistribution" title="a wavelength probability distribution with a configured wavelength range">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength of the wavelength probability distribution" default="1 pm" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength of the wavelength probability distribution" default="1 m" min="1 pm" max="1 m" quantity="wavelength"/>
                </properties>
            </Type>
            <Type name="RedistributeGeometryDecorator" base="Geometry" title="a decorator that redistributes another geometry" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry for which the density will be redistributed" base="Geometry"/>
                </properties>
            </Type>
            <Type name="ResourceSED" base="ContSED" title="a spectral energy distribution loaded from a resource"/>
            <Type name="SED" base="SimulationItem" title="a spectral energy distribution"/>
            <Type name="SEDFamily" base="SimulationItem" title="an SED family"/>
            <Type name="SepAxGeometry" base="AxGeometry" title="a separable axisymmetric geometry"/>
            <Type name="Simulation" base="SimulationItem" title="the simulation">
                <properties type="Property">
                    <EnumProperty name="userLevel" title="the user experience level" insert="userLevelBasic:Level1;userLevelRegular:Level1,Level2;userLevelExpert:Level1,Level2,Level3" default="Regular">
                        <enumValues type="EnumValue">
                            <EnumValue name="Basic" title="Basic: for beginning users (hides many options)"/>
                            <EnumValue name="Regular" title="Regular: for regular users (hides esoteric options)"/>
                            <EnumValue name="Expert" title="Expert: for expert users (hides no options)"/>
                        </enumValues>
                    </EnumProperty>
                    <ItemProperty name="random" title="the random number generator" displayedIf="Level3" default="Random" base="Random"/>
                    <ItemProperty name="units" title="the units system" default="ExtragalacticUnits" base="Units"/>
                </properties>
            </Type>
            <Type name="SimulationItem" base="Item" title="a simulation item"/>
            <Type name="SingleGrainDustMix" base="DustMix" title="a dust mix described by a single representative grain" allowedIf="!StochasticDustEmission"/>
            <Type name="SmoothingKernel" base="SimulationItem" title="a smoothing kernel"/>
            <Type name="Source" base="SimulationItem" title="a primary radiation source" subPropertyIndex="0">
                <properties type="Property">
                    <DoubleProperty name="sourceWeight" title="the weight of this source for the number of photon packets launched" displayedIf="Level3" default="1" min="]0" max="1000]"/>
                    <DoubleProperty name="wavelengthBias" title="the fraction of photon packet wavelengths sampled from a bias distribution" relevantIf="Panchromatic" displayedIf="Level3" default="0.5" min="[0" max="1]"/>
                    <ItemProperty name="wavelengthBiasDistribution" title="the bias distribution for sampling photon packet wavelengths" relevantIf="Panchromatic&amp;wavelengthBias" displayedIf="Level3" default="DefaultWavelengthDistribution" base="WavelengthDistribution"/>
                </properties>
            </Type>
            <Type name="SpatialCellLibrary" base="SimulationItem" title="a library scheme for grouping spatial cells"/>
            <Type name="SpatialGrid" base="SimulationItem" title="a spatial grid"/>
            <Type name="SpatialGridForm" base="Form" title="a spatial grid-specific probe form"/>
            <Type name="SpatialGridFormProbe" base="Probe" title="a spatial grid form probe">
                <properties type="Property">
                    <ItemProperty name="form" title="the form describing how this quantity should be probed" default="DefaultCutsForm" base="Form"/>
                </properties>
            </Type>
            <Type name="SpatialGridWhenFormProbe" base="SpatialGridFormProbe" title="a spatial grid when form probe" subPropertyIndex="0">
                <properties type="Property">
                    <EnumProperty name="probeAfter" title="perform the probe after" displayedIf="DynamicState|IterateSecondary" default="thisIsTemperatureProbe&amp;DustMix:Run;Setup">
                        <enumValues type="EnumValue">
                            <EnumValue name="Setup" title="after setup"/>
                            <EnumValue name="Run" title="after the complete simulation run"/>
                            <EnumValue name="Primary" title="after each iteration over primary emission"/>
                            <EnumValue name="Secondary" title="after each iteration over secondary emission"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SpecialtyProbe" base="Probe" title="a specialty probe"/>
            <Type name="SpecialtySource" base="NormalizedSource" title="a primary source with a single bulk velocity" subPropertyIndex="0">
                <properties type="Property">
                    <DoubleProperty name="velocityX" title="the bulk velocity of the source, x component" relevantIf="Panchromatic" displayedIf="Level2" insert="Panchromatic&amp;velocityX:Dimension3" default="0" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                    <DoubleProperty name="velocityY" title="the bulk velocity of the source, y component" relevantIf="Panchromatic" displayedIf="Level2" insert="Panchromatic&amp;velocityY:Dimension3" default="0" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                    <DoubleProperty name="velocityZ" title="the bulk velocity of the source, z component" relevantIf="Panchromatic" displayedIf="Level2" insert="Panchromatic&amp;velocityZ:Dimension2" default="0" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                </properties>
            </Type>
            <Type name="SpecialtyWavelengthGridProbe" base="SpecialtyProbe" title="a specialty wavelength grid probe">
                <properties type="Property">
                    <ItemProperty name="wavelengthGrid" title="the wavelength grid for this probe" relevantIf="Panchromatic" displayedIf="Level2" requiredIf="!DefaultInstrumentWavelengthGrid" base="WavelengthGrid"/>
                </properties>
            </Type>
            <Type name="SpecialtyWavelengthProbe" base="SpecialtyWhenProbe" title="a specialty wavelength probe">
                <properties type="Property">
                    <DoubleProperty name="wavelength" title="the wavelength at which to determine the optical depth" default="0.55 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                </properties>
            </Type>
            <Type name="SpecialtyWhenProbe" base="SpecialtyProbe" title="a specialty when probe" subPropertyIndex="0">
                <properties type="Property">
                    <EnumProperty name="probeAfter" title="perform the probe after" displayedIf="DynamicState" default="Setup">
                        <enumValues type="EnumValue">
                            <EnumValue name="Setup" title="after setup"/>
                            <EnumValue name="Run" title="after the complete simulation run"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SpheGeometry" base="Geometry" title="a spherically symmetric geometry"/>
            <Type name="SphereSpatialGrid" base="SpatialGrid" title="a spatial grid bounded by a sphere">
                <properties type="Property">
                    <DoubleProperty name="minRadius" title="the inner radius of the grid" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the outer radius of the grid" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="TabulatedBand" base="Band" title="a wavelength band (transmission curve) tabulated by the user" displayedIf="Level2"/>
            <Type name="TabulatedDustMix" base="DustMix" title="a basic dust mix with properties tabulated by the user" allowedIf="!StochasticDustEmission" displayedIf="Level2"/>
            <Type name="TabulatedMesh" base="Mesh" title="a mesh tabulated by the user" displayedIf="Level2"/>
            <Type name="TabulatedSED" base="ContSED" title="a spectral energy distribution tabulated by the user"/>
            <Type name="TabulatedWavelengthDistribution" base="WavelengthDistribution" title="a wavelength probability distribution tabulated by the user"/>
            <Type name="TreePolicy" base="SimulationItem" title="a spatial tree grid construction policy">
                <properties type="Property">
                    <IntProperty name="minLevel" title="the minimum level of grid refinement" default="OctTreeGrid:3;BinTreeGrid:9" min="0" max="99"/>
                    <IntProperty name="maxLevel" title="the maximum level of grid refinement" default="OctTreeGrid:7;BinTreeGrid:21" min="0" max="99"/>
                </properties>
            </Type>
            <Type name="TreeSpatialGrid" base="BoxSpatialGrid" title="a hierarchical tree spatial grid"/>
            <Type name="Units" base="SimulationItem" title="a units system">
                <properties type="Property">
                    <EnumProperty name="wavelengthOutputStyle" title="the output style for wavelengths" default="Wavelength">
                        <enumValues type="EnumValue">
                            <EnumValue name="Wavelength" title="as photon wavelength: λ"/>
                            <EnumValue name="Frequency" title="as photon frequency: ν"/>
                            <EnumValue name="Energy" title="as photon energy: E"/>
                        </enumValues>
                    </EnumProperty>
                    <EnumProperty name="fluxOutputStyle" title="the output style for flux density and surface brightness" default="wavelengthOutputStyleEnergy:Energy;Frequency">
                        <enumValues type="EnumValue">
                            <EnumValue name="Neutral" title="neutral: λ F_λ = ν F_ν"/>
                            <EnumValue name="Wavelength" title="per unit of wavelength: F_λ"/>
                            <EnumValue name="Frequency" title="per unit of frequency: F_ν"/>
                            <EnumValue name="Energy" title="counts per unit of energy: F_E"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="VectorField" base="SimulationItem" title="a vector field"/>
            <Type name="WavelengthDistribution" base="SimulationItem" title="a wavelength probability distribution"/>
            <Type name="WavelengthGrid" base="SimulationItem" title="a wavelength grid"/>
            <!--Concrete types, in order of addition to the registry-->
            <Type name="Random" base="SimulationItem" title="the default random generator" concrete="true">
                <properties type="Property">
                    <IntProperty name="seed" title="the seed for the random generator" displayedIf="Level3" default="0" min="0" max="1000000"/>
                </properties>
            </Type>
            <Type name="SIUnits" base="Units" title="SI units" concrete="true"/>
            <Type name="StellarUnits" base="Units" title="stellar units (length in AU, distance in pc)" concrete="true"/>
            <Type name="ExtragalacticUnits" base="Units" title="extragalactic units (length in pc, distance in Mpc)" concrete="true"/>
            <Type name="LocalUniverseCosmology" base="Cosmology" title="the model is at redshift zero in the Local Universe" concrete="true"/>
            <Type name="FlatUniverseCosmology" base="Cosmology" title="the model is at a given redshift in a flat universe" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="redshift" title="the redshift z of the model coordinate frame" insert="redshift:NonZeroRedshift" default="1" min="[0" max="15]"/>
                    <DoubleProperty name="reducedHubbleConstant" title="the reduced Hubble constant h" relevantIf="redshift" default="0.675" min="0.3" max="1"/>
                    <DoubleProperty name="matterDensityFraction" title="the cosmological matter density fraction Ω_m" relevantIf="redshift" default="0.310" min="0.1" max="0.9"/>
                </properties>
            </Type>
            <Type name="SourceSystem" base="SimulationItem" title="a primary source system" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength of photon packets launched from primary sources" relevantIf="Panchromatic" default="0.09 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength of photon packets launched from primary sources" relevantIf="Panchromatic" default="100 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleListProperty name="wavelengths" title="the discrete wavelengths of photon packets launched from primary sources" relevantIf="Oligochromatic" default="0.55 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="sourceBias" title="the fraction of photon packets distributed uniformly across primary sources" displayedIf="Level3" default="0.5" min="[0" max="1]"/>
                    <ItemListProperty name="sources" title="the primary sources" requiredIf="false" default="GeometricSource" base="Source"/>
                </properties>
            </Type>
            <Type name="PointSource" base="SpecialtySource" title="a primary point source" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="positionX" title="the position of the point source, x component" insert="positionX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="positionY" title="the position of the point source, y component" insert="positionY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="positionZ" title="the position of the point source, z component" insert="positionZ:Dimension2" default="0" quantity="length"/>
                    <ItemProperty name="angularDistribution" title="the angular luminosity distribution of the emission" displayedIf="Level2" requiredIf="false" default="IsotropicAngularDistribution" base="AngularDistribution"/>
                    <ItemProperty name="polarizationProfile" title="the polarization profile of the emission" displayedIf="Level2" requiredIf="false" default="NoPolarizationProfile" base="PolarizationProfile"/>
                </properties>
            </Type>
            <Type name="GeometricSource" base="NormalizedSource" title="a primary source with a built-in geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry of the spatial luminosity distribution for the source" default="PlummerGeometry" base="Geometry"/>
                    <ItemProperty name="velocityDistribution" title="the spatial distribution of the velocity, if any" relevantIf="Panchromatic" displayedIf="Level2" requiredIf="false" base="VectorField"/>
                    <DoubleProperty name="velocityMagnitude" title="the magnitude of the velocity (multiplier)" relevantIf="Panchromatic&amp;velocityDistribution" displayedIf="Level2" insert="velocityDistribution&amp;velocityMagnitude:SourceVelocity" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                </properties>
            </Type>
            <Type name="ParticleSource" base="ImportedSource" title="a primary source imported from smoothed particle data" concrete="true">
                <properties type="Property">
                    <ItemProperty name="smoothingKernel" title="the kernel for interpolating the smoothed particles" displayedIf="Level2" default="CubicSplineSmoothingKernel" base="SmoothingKernel"/>
                </properties>
            </Type>
            <Type name="CellSource" base="ImportedSource" title="a primary source imported from cuboidal cell data" concrete="true"/>
            <Type name="CylindricalCellSource" base="ImportedSource" title="a primary source imported from cylindrical cell data" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <BoolProperty name="autoRevolve" title="automatically revolve 2D data to a 3D model" default="false"/>
                    <IntProperty name="numAutoRevolveBins" title="the number of azimuth bins for auto-revolving 2D data" relevantIf="autoRevolve" default="16" min="2" max="1024"/>
                </properties>
            </Type>
            <Type name="SphericalCellSource" base="ImportedSource" title="a primary source imported from spherical cell data" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="autoRevolve" title="automatically revolve 1D or 2D data to a 3D model" default="None">
                        <enumValues type="EnumValue">
                            <EnumValue name="None" title="no auto-revolve"/>
                            <EnumValue name="Inclination" title="auto-revolve inclination"/>
                            <EnumValue name="Azimuth" title="auto-revolve azimuth"/>
                            <EnumValue name="InclinationAndAzimuth" title="auto-revolve both inclination and azimuth"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numInclinationRevolveBins" title="the number of inclination bins for auto-revolving 1D or 2D data" relevantIf="autoRevolveInclination|autoRevolveInclinationAndAzimuth" default="16" min="2" max="1024"/>
                    <IntProperty name="numAzimuthRevolveBins" title="the number of azimuth bins for auto-revolving 1D or 2D data" relevantIf="autoRevolveAzimuth|autoRevolveInclinationAndAzimuth" default="16" min="2" max="1024"/>
                </properties>
            </Type>
            <Type name="AdaptiveMeshSource" base="MeshSource" title="a primary source imported from data represented on an adaptive mesh (AMR grid)" concrete="true"/>
            <Type name="VoronoiMeshSource" base="MeshSource" title="a primary source imported from data represented on a Voronoi mesh" concrete="true"/>
            <Type name="StellarSurfaceSource" base="CenteredSource" title="a stellar surface source with an anisotropic outward radiation field" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="stellarRadius" title="the stellar radius" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="CubicalBackgroundSource" base="CenteredSource" title="a cubical background source with an anisotropic inward radiation field" concrete="true" insert="Dimension3">
                <properties type="Property">
                    <DoubleProperty name="edgeLength" title="the edge length of the background cube" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="SphericalBackgroundSource" base="CenteredSource" title="a spherical background source with an anisotropic inward radiation field" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="backgroundRadius" title="the radius of the background sphere" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="FilePolarizedPointSource" base="Source" title="a primary point source with a polarized spectrum read from file" concrete="true" displayedIf="Level2" insert="Dimension2,ContSED">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the stored table file listing the Stokes vector components"/>
                    <ItemProperty name="normalization" title="the type of luminosity normalization for the source" default="IntegratedLuminosityNormalization" base="LuminosityNormalization"/>
                    <DoubleProperty name="positionX" title="the position of the point source, x component" insert="positionX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="positionY" title="the position of the point source, y component" insert="positionY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="positionZ" title="the position of the point source, z component" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryX" title="the direction of the positive symmetry axis, x component" insert="symmetryX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryY" title="the direction of the positive symmetry axis, y component" insert="symmetryY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryZ" title="the direction of the positive symmetry axis, z component" default="1" quantity="length"/>
                    <DoubleProperty name="velocityX" title="the bulk velocity of the point source, x component" relevantIf="Panchromatic" insert="Panchromatic&amp;velocityX:Dimension3" default="0" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                    <DoubleProperty name="velocityY" title="the bulk velocity of the point source, y component" relevantIf="Panchromatic" insert="Panchromatic&amp;velocityY:Dimension3" default="0" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                    <DoubleProperty name="velocityZ" title="the bulk velocity of the point source, z component" relevantIf="Panchromatic" default="0" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                </properties>
            </Type>
            <Type name="IntegratedLuminosityNormalization" base="LuminosityNormalization" title="source normalization through the integrated luminosity for a given wavelength range" concrete="true">
                <properties type="Property">
                    <EnumProperty name="wavelengthRange" title="the wavelength range for which to provide the integrated luminosity" default="Source">
                        <enumValues type="EnumValue">
                            <EnumValue name="Source" title="the wavelength range of the primary sources"/>
                            <EnumValue name="All" title="all wavelengths (i.e. over the full SED)"/>
                            <EnumValue name="Custom" title="a custom wavelength range specified here"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="minWavelength" title="the shortest wavelength of the integration range" relevantIf="wavelengthRangeCustom" default="0.09 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength of the integration range" relevantIf="wavelengthRangeCustom" default="100 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="integratedLuminosity" title="the integrated luminosity for the given wavelength range" min="]0" quantity="bolluminosity"/>
                </properties>
            </Type>
            <Type name="SpecificLuminosityNormalization" base="LuminosityNormalization" title="source normalization through the specific luminosity at a given wavelength" concrete="true" allowedIf="ContSED">
                <properties type="Property">
                    <DoubleProperty name="wavelength" title="the wavelength at which to provide the specific luminosity" min="1 pm" max="1 m" quantity="wavelength"/>
                    <EnumProperty name="unitStyle" title="the luminosity unit style" default="wavelengthmonluminosity">
                        <enumValues type="EnumValue">
                            <EnumValue name="neutralmonluminosity" title="neutral: λ L_λ = ν L_ν"/>
                            <EnumValue name="wavelengthmonluminosity" title="per unit of wavelength: L_λ"/>
                            <EnumValue name="frequencymonluminosity" title="per unit of frequency: L_ν"/>
                            <EnumValue name="energymonluminosity" title="counts per unit of energy: L_E"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="specificLuminosity" title="the specific luminosity at the given wavelength" min="]0" quantity="@unitStyle"/>
                </properties>
            </Type>
            <Type name="BandLuminosityNormalization" base="LuminosityNormalization" title="source normalization through the specific luminosity for a given wavelength band" concrete="true" allowedIf="ContSED">
                <properties type="Property">
                    <ItemProperty name="band" title="the wavelength band for which to provide the specific luminosity" default="BroadBand" base="Band"/>
                    <EnumProperty name="unitStyle" title="the luminosity unit style" default="wavelengthmonluminosity">
                        <enumValues type="EnumValue">
                            <EnumValue name="neutralmonluminosity" title="neutral: λ L_λ = ν L_ν"/>
                            <EnumValue name="wavelengthmonluminosity" title="per unit of wavelength: L_λ"/>
                            <EnumValue name="frequencymonluminosity" title="per unit of frequency: L_ν"/>
                            <EnumValue name="energymonluminosity" title="counts per unit of energy: L_E"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="specificLuminosity" title="the specific luminosity for the given band" min="]0" quantity="@unitStyle"/>
                </properties>
            </Type>
            <Type name="LineLuminosityNormalization" base="LuminosityNormalization" title="source normalization through the luminosity for a given emission line" concrete="true" allowedIf="LineSED" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="wavelength" title="the central wavelength of the emission line" default="1215.67 Angstrom" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="luminosity" title="the luminosity for the emission line" min="]0" quantity="bolluminosity"/>
                </properties>
            </Type>
            <Type name="BlackBodySED" base="ContSED" title="a black-body spectral energy distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="temperature" title="the black body temperature" default="5000 K" min="]0 K" quantity="temperature"/>
                </properties>
            </Type>
            <Type name="SunSED" base="ResourceSED" title="the spectral energy distribution of the Sun" concrete="true"/>
            <Type name="QuasarSED" base="ResourceSED" title="the spectral energy distribution of a typical quasar" concrete="true"/>
            <Type name="CastelliKuruczSED" base="FamilySED" title="a Castelli-Kurucz stellar atmosphere SED" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="metallicity" title="the stellar metallicity" default="0.02" min="[0.00006" max="0.06]"/>
                    <DoubleProperty name="temperature" title="the effective surface temperature" default="5000 K" min="]3500 K" max="50000 K]" quantity="temperature"/>
                    <DoubleProperty name="gravity" title="the surface gravity" default="275 m/s2" min="[0.01 m/s2" max="1000 m/s2]" quantity="acceleration"/>
                </properties>
            </Type>
            <Type name="BruzualCharlotSED" base="FamilySED" title="a Bruzual-Charlot simple stellar population SED" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="the assumed initial mass function" default="Chabrier">
                        <enumValues type="EnumValue">
                            <EnumValue name="Chabrier" title="Chabrier IMF"/>
                            <EnumValue name="Salpeter" title="Salpeter IMF"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="metallicity" title="the metallicity of the SSP" default="0.02" min="[0.0001" max="0.05]"/>
                    <DoubleProperty name="age" title="the age of the SSP" default="5 Gyr" min="[0 Gyr" max="20 Gyr]" quantity="time"/>
                </properties>
            </Type>
            <Type name="MarastonSED" base="FamilySED" title="a Maraston simple stellar population SED" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="the assumed initial mass function" default="Kroupa">
                        <enumValues type="EnumValue">
                            <EnumValue name="Kroupa" title="Kroupa IMF"/>
                            <EnumValue name="Salpeter" title="Salpeter IMF"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="metallicity" title="the metallicity of the SSP" default="0.02" min="[0.0001" max="0.09]"/>
                    <DoubleProperty name="age" title="the age of the SSP" default="5 Gyr" min="[1000 yr" max="15 Gyr]" quantity="time"/>
                </properties>
            </Type>
            <Type name="Starburst99SED" base="FamilySED" title="a Starburst99 simple stellar population SED" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="metallicity" title="the metallicity of the SSP" default="0.02" min="[0.001" max="0.04]"/>
                    <DoubleProperty name="age" title="the age of the SSP" default="5 Myr" min="[1e4 yr" max="1.049e+09 yr]" quantity="time"/>
                </properties>
            </Type>
            <Type name="FSPSSED" base="FamilySED" title="an FSPS simple stellar population SED" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="the assumed initial mass function" default="Chabrier">
                        <enumValues type="EnumValue">
                            <EnumValue name="Chabrier" title="Chabrier IMF"/>
                            <EnumValue name="Kroupa" title="Kroupa IMF"/>
                            <EnumValue name="Salpeter" title="Salpeter IMF"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="metallicity" title="the metallicity of the SSP" default="0.02" min="[0.0001" max="0.05]"/>
                    <DoubleProperty name="age" title="the age of the SSP" default="5 Gyr" min="[0 Gyr" max="20 Gyr]" quantity="time"/>
                </properties>
            </Type>
            <Type name="BpassSED" base="FamilySED" title="a BPASS single stellar population SED" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="metallicity" title="the metallicity of the SSP" default="0.02" min="[1e-5" max="0.04]"/>
                    <DoubleProperty name="age" title="the age of the SSP" default="5 Gyr" min="[1 Myr" max="100 Gyr]" quantity="time"/>
                </properties>
            </Type>
            <Type name="MappingsSED" base="FamilySED" title="a star-forming region SED from the MAPPINGS III model" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="metallicity" title="the metallicity" default="0.0122" min="[0.0006" max="0.025]"/>
                    <DoubleProperty name="compactness" title="the logarithm of the compactness parameter" default="6.0" min="[4.0" max="6.5]"/>
                    <DoubleProperty name="pressure" title="the ISM pressure" default="1e11 K/m3" min="[1e10 K/m3" max="1e14 K/m3]" quantity="pressure"/>
                    <DoubleProperty name="coveringFactor" title="the PDR covering factor" default="0.2" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="ToddlersSED" base="FamilySED" title="a Toddlers SED for emission from star-forming regions" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="metallicity" title="metallicity" default="0.02" min="[0.001" max="0.04]"/>
                    <DoubleProperty name="SFE" title="star formation efficiency " default=".025" min="[.01" max=".15]"/>
                    <DoubleProperty name="cloudNumDensity" title="initial cloud number density" default="320 /cm3" min="[10 /cm3" max="2560 /cm3]" quantity="numbervolumedensity"/>
                </properties>
            </Type>
            <Type name="FileSED" base="TabulatedSED" title="a spectral energy distribution loaded from a text file" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the spectral energy distribution"/>
                </properties>
            </Type>
            <Type name="ListSED" base="TabulatedSED" title="a spectral energy distribution specified inside the configuration file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the wavelengths at which to specify the specific luminosity" min="1 pm" max="1 m" quantity="wavelength"/>
                    <EnumProperty name="unitStyle" title="the luminosity unit style" default="wavelengthmonluminosity">
                        <enumValues type="EnumValue">
                            <EnumValue name="neutralmonluminosity" title="neutral: λ L_λ = ν L_ν"/>
                            <EnumValue name="wavelengthmonluminosity" title="per unit of wavelength: L_λ"/>
                            <EnumValue name="frequencymonluminosity" title="per unit of frequency: L_ν"/>
                            <EnumValue name="energymonluminosity" title="counts per unit of energy: L_E"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleListProperty name="specificLuminosities" title="the specific luminosities at each of the given wavelengths" min="]0" quantity="@unitStyle"/>
                </properties>
            </Type>
            <Type name="LyaGaussianSED" base="ContSED" title="a Gaussian spectrum around the central Lyman-alpha wavelength" concrete="true" displayedIf="Lya|Level3">
                <properties type="Property">
                    <DoubleProperty name="dispersion" title="the Gaussian velocity dispersion" default="50 km/s" min="]0 km/s" max="1000 km/s]" quantity="velocity"/>
                </properties>
            </Type>
            <Type name="LyaDoublePeakedSED" base="ContSED" title="a double-peaked spectrum around the central Lyman-alpha wavelength" concrete="true" displayedIf="Lya|Level3">
                <properties type="Property">
                    <DoubleProperty name="scale" title="the velocity scale" default="50 km/s" min="]0 km/s" max="1000 km/s]" quantity="velocity"/>
                </properties>
            </Type>
            <Type name="LyaSEDDecorator" base="ContSED" title="an SED decorator replacing ionizing radiation with Lyman-alpha line emission" concrete="true" displayedIf="Lya|Level3">
                <properties type="Property">
                    <ItemProperty name="sedOriginal" title="the original SED being adjusted" default="BlackBodySED" base="ContSED"/>
                    <ItemProperty name="sedLymanAlpha" title="the SED representing the Lyman-alpha line emission" default="LyaGaussianSED" base="ContSED"/>
                    <DoubleProperty name="conversionFraction" title="the fraction of ionizing radiation replaced by Lyman-alpha emission" default="0.5" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="FileLineSED" base="LineSED" title="a discrete line SED loaded from a text file" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the line definitions"/>
                </properties>
            </Type>
            <Type name="ListLineSED" base="LineSED" title="a discrete line SED specified inside the configuration file" concrete="true">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the line wavelengths" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleListProperty name="luminosities" title="the line luminosities" min="[0" quantity="bolluminosity"/>
                </properties>
            </Type>
            <Type name="SingleWavelengthSED" base="LineSED" title="a single-wavelength SED in the form of a Dirac-delta function" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="wavelength" title="the single emission wavelength" default="1215.67 Angstrom" min="1 pm" max="1 m" quantity="wavelength"/>
                </properties>
            </Type>
            <Type name="BlackBodySEDFamily" base="SEDFamily" title="a black body SED family" concrete="true"/>
            <Type name="CastelliKuruczSEDFamily" base="SEDFamily" title="a Castelli-Kurucz SED family for stellar atmospheres" concrete="true"/>
            <Type name="BruzualCharlotSEDFamily" base="SEDFamily" title="a Bruzual-Charlot SED family for single stellar populations" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="the assumed initial mass function" default="Chabrier">
                        <enumValues type="EnumValue">
                            <EnumValue name="Chabrier" title="Chabrier IMF"/>
                            <EnumValue name="Salpeter" title="Salpeter IMF"/>
                        </enumValues>
                    </EnumProperty>
                    <EnumProperty name="resolution" title="the wavelength resolution" default="Low">
                        <enumValues type="EnumValue">
                            <EnumValue name="Low" title="Low wavelength resolution (1221 points)"/>
                            <EnumValue name="High" title="High wavelength resolution (6900 points)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MarastonSEDFamily" base="SEDFamily" title="a Maraston SED family for single stellar populations" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="the assumed initial mass function" default="Kroupa">
                        <enumValues type="EnumValue">
                            <EnumValue name="Kroupa" title="Kroupa IMF"/>
                            <EnumValue name="Salpeter" title="Salpeter IMF"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="Starburst99SEDFamily" base="SEDFamily" title="a Starburst99 SED family for single stellar populations" concrete="true"/>
            <Type name="FSPSSEDFamily" base="SEDFamily" title="an FSPS SED family for single stellar populations" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="the assumed initial mass function" default="Chabrier">
                        <enumValues type="EnumValue">
                            <EnumValue name="Chabrier" title="Chabrier IMF"/>
                            <EnumValue name="Kroupa" title="Kroupa IMF"/>
                            <EnumValue name="Salpeter" title="Salpeter IMF"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="BpassSEDFamily" base="SEDFamily" title="a BPASS SED family for single stellar populations" concrete="true">
                <properties type="Property">
                    <EnumProperty name="imf" title="IMF" default="Chabrier300">
                        <enumValues type="EnumValue">
                            <EnumValue name="Chabrier100" title="Chabrier IMF (0.1-100 Msun)"/>
                            <EnumValue name="Chabrier300" title="Chabrier IMF (0.1-300 Msun)"/>
                        </enumValues>
                    </EnumProperty>
                    <EnumProperty name="resolution" title="the wavelength resolution" default="Original">
                        <enumValues type="EnumValue">
                            <EnumValue name="Original" title="Original wavelength resolution and range"/>
                            <EnumValue name="Downsampled" title="Downsampled wavelength resolution and extended wavelength range"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="FileSSPSEDFamily" base="SEDFamily" title="a user-provided SED family for single stellar populations" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the stored table file defining the SED templates"/>
                    <BoolProperty name="hasIonizationParameter" title="include ionization U as an extra parameter for the SED family" displayedIf="Level2" default="false"/>
                </properties>
            </Type>
            <Type name="FileIndexedSEDFamily" base="SEDFamily" title="a user-provided, indexed SED family" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the stored table file listing the SEDs"/>
                </properties>
            </Type>
            <Type name="MappingsSEDFamily" base="SEDFamily" title="a MAPPINGS III SED family for star-forming regions" concrete="true" displayedIf="Level2"/>
            <Type name="ToddlersSEDFamily" base="SEDFamily" title="a TODDLERS SED family for emission from star-forming regions" concrete="true">
                <properties type="Property">
                    <EnumProperty name="sedMode" title="SED calculation mode" default="SFRNormalized">
                        <enumValues type="EnumValue">
                            <EnumValue name="SFRNormalized" title="SEDs normalized by star formation rate"/>
                            <EnumValue name="Cloud" title="Individual cloud SEDs with time evolution"/>
                        </enumValues>
                    </EnumProperty>
                    <EnumProperty name="stellarTemplate" title="the stellar template, IMF, and evolution model to use" default="SB99Kroupa100Sin">
                        <enumValues type="EnumValue">
                            <EnumValue name="SB99Kroupa100Sin" title="Starburst99 with Kroupa IMF (0.1-100 Msun) and single star evolution"/>
                            <EnumValue name="BPASSChab100Bin" title="BPASS with Chabrier IMF (0.1-100 Msun) and binary star evolution"/>
                            <EnumValue name="BPASSChab300Bin" title="BPASS with Chabrier IMF (0.1-300 Msun) and binary star evolution"/>
                        </enumValues>
                    </EnumProperty>
                    <BoolProperty name="includeDust" title="include dust processing in the SED models" default="true"/>
                    <EnumProperty name="resolution" title="the wavelength resolution" default="Low">
                        <enumValues type="EnumValue">
                            <EnumValue name="Low" title="Low wavelength resolution (continuum and lines at R=300)"/>
                            <EnumValue name="High" title="High wavelength resolution (continuum at R=300 and lines at R=5e4)"/>
                        </enumValues>
                    </EnumProperty>
                    <EnumProperty name="sfrPeriod" title="the SFR integration time period" relevantIf="sedModeSFRNormalized" default="Period10Myr">
                        <enumValues type="EnumValue">
                            <EnumValue name="Period10Myr" title="SFR integrated over 10 Myr"/>
                            <EnumValue name="Period30Myr" title="SFR integrated over 30 Myr"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SpinFlipSEDFamily" base="SEDFamily" title="a family of Gaussian spectra around the central spin-flip wavelength" concrete="true"/>
            <Type name="LyaGaussianSEDFamily" base="SEDFamily" title="a family of Gaussian spectra around the central Lyman-alpha wavelength" concrete="true" displayedIf="Lya|Level3"/>
            <Type name="LyaDoublePeakedSEDFamily" base="SEDFamily" title="a family of double-peaked spectra around the central Lyman-alpha wavelength" concrete="true" displayedIf="Lya|Level3"/>
            <Type name="LyaSEDFamilyDecorator" base="SEDFamily" title="an SED family decorator replacing ionizing radiation with Lyman-alpha line emission" concrete="true" displayedIf="Lya|Level3">
                <properties type="Property">
                    <ItemProperty name="sedFamilyOriginal" title="the original SED family being adjusted" default="BlackBodySEDFamily" base="SEDFamily"/>
                    <ItemProperty name="sedLymanAlpha" title="the SED representing the Lyman-alpha line emission" default="LyaGaussianSED" base="ContSED"/>
                    <DoubleProperty name="conversionFraction" title="the fraction of ionizing radiation replaced by Lyman-alpha emission" default="0.5" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="DefaultWavelengthDistribution" base="WavelengthDistribution" title="the default (logarithmic) wavelength probability distribution" concrete="true"/>
            <Type name="LinWavelengthDistribution" base="RangeWavelengthDistribution" title="a linear wavelength probability distribution" concrete="true"/>
            <Type name="LogWavelengthDistribution" base="RangeWavelengthDistribution" title="a logarithmic wavelength probability distribution" concrete="true"/>
            <Type name="FileWavelengthDistribution" base="TabulatedWavelengthDistribution" title="a wavelength probability distribution loaded from a text file" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the wavelength probability distribution"/>
                </properties>
            </Type>
            <Type name="ListWavelengthDistribution" base="TabulatedWavelengthDistribution" title="a wavelength probability distribution specified inside the configuration file" concrete="true">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the wavelengths at which to specify the probability" min="1 pm" max="1 m" quantity="wavelength"/>
                    <EnumProperty name="unitStyle" title="the probability unit style" default="wavelengthmonluminosity">
                        <enumValues type="EnumValue">
                            <EnumValue name="neutralmonluminosity" title="neutral: λ L_λ = ν L_ν"/>
                            <EnumValue name="wavelengthmonluminosity" title="per unit of wavelength: L_λ"/>
                            <EnumValue name="frequencymonluminosity" title="per unit of frequency: L_ν"/>
                            <EnumValue name="energymonluminosity" title="counts per unit of energy: L_E"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleListProperty name="probabilities" title="the probabilities at each of the given wavelengths" min="]0" quantity="@unitStyle"/>
                </properties>
            </Type>
            <Type name="DiscreteWavelengthDistribution" base="WavelengthDistribution" title="a discrete wavelength probability distribution derived from a wavelength grid" concrete="true">
                <properties type="Property">
                    <ItemProperty name="wavelengthGrid" title="the wavelength grid defining the discrete distribution" default="FileWavelengthGrid" base="DisjointWavelengthGrid"/>
                </properties>
            </Type>
            <Type name="BroadBand" base="Band" title="a standard built-in broadband (transmission curve)" concrete="true">
                <properties type="Property">
                    <StringProperty name="bandName" title="the name of the standard broadband (e.g. &apos;Johnson V&apos; or &apos;PACS 100&apos;)"/>
                </properties>
            </Type>
            <Type name="FileBand" base="TabulatedBand" title="a wavelength band (transmission curve) loaded from a text file" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file defining the transmission curve"/>
                </properties>
            </Type>
            <Type name="ListBand" base="TabulatedBand" title="a wavelength band (transmission curve) specified inside the configuration file" concrete="true">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the wavelengths at which to specify the transmission" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleListProperty name="transmissionValues" title="the transmission at each of the given wavelengths" min="]0"/>
                </properties>
            </Type>
            <Type name="IsotropicAngularDistribution" base="AngularDistribution" title="an isotropic emission profile" concrete="true"/>
            <Type name="LaserAngularDistribution" base="AxAngularDistribution" title="a laser emission profile" concrete="true"/>
            <Type name="ConicalAngularDistribution" base="AxAngularDistribution" title="an anisotropic conical emission profile" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="openingAngle" title="the (half) opening angle of the cone" min="]0 deg" max="90 deg]" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="NetzerAngularDistribution" base="AxAngularDistribution" title="a Netzer AGN accretion disk emission profile" concrete="true"/>
            <Type name="NoPolarizationProfile" base="PolarizationProfile" title="an unpolarized emission profile" concrete="true"/>
            <Type name="SineSquarePolarizationProfile" base="PolarizationProfile" title="an axysimmetric sine-square polarization emission profile" concrete="true" insert="Dimension2">
                <properties type="Property">
                    <DoubleProperty name="symmetryX" title="the direction of the positive symmetry axis, x component" insert="symmetryX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryY" title="the direction of the positive symmetry axis, y component" insert="symmetryY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="symmetryZ" title="the direction of the positive symmetry axis, z component" default="1" quantity="length"/>
                    <DoubleProperty name="maxPolarizationDegree" title="the maximum linear polarization degree" default="0.1" min="[0" max="1]"/>
                    <DoubleProperty name="polarizationAngle" title="the linear polarization angle" default="30 deg" min="[0 deg" max="180 deg]" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="PlummerGeometry" base="SpheGeometry" title="a Plummer geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="scaleLength" title="the scale length" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="GammaGeometry" base="SpheGeometry" title="a gamma geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="scaleLength" title="the scale length" min="]0" quantity="length"/>
                    <DoubleProperty name="gamma" title="the central density slope γ" default="1" min="[0" max="3["/>
                </properties>
            </Type>
            <Type name="SersicGeometry" base="SpheGeometry" title="a Sérsic geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="effectiveRadius" title="the effective radius" min="]0" quantity="length"/>
                    <DoubleProperty name="index" title="the Sérsic index n" default="1" min="]0.5" max="10]"/>
                </properties>
            </Type>
            <Type name="PseudoSersicGeometry" base="SpheGeometry" title="a pseudo-Sérsic geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="effectiveRadius" title="the effective radius" min="]0" quantity="length"/>
                    <DoubleProperty name="index" title="the Sérsic index n" default="1" min="]0.5" max="10]"/>
                </properties>
            </Type>
            <Type name="EinastoGeometry" base="SpheGeometry" title="an Einasto geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="halfMassRadius" title="the half-mass radius" min="]0" quantity="length"/>
                    <DoubleProperty name="index" title="the Einasto index n" min="]0"/>
                </properties>
            </Type>
            <Type name="GaussianGeometry" base="SpheGeometry" title="a Gaussian geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="dispersion" title="the scale length (dispersion) σ" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="ShellGeometry" base="SpheGeometry" title="a shell geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minRadius" title="the inner radius of the shell" min="]0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the outer radius of the shell" min="]0" quantity="length"/>
                    <DoubleProperty name="exponent" title="the power law exponent"/>
                </properties>
            </Type>
            <Type name="ExpDiskGeometry" base="SepAxGeometry" title="an exponential disk geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="scaleLength" title="the scale length" min="]0" quantity="length"/>
                    <DoubleProperty name="scaleHeight" title="the scale height" min="]0" quantity="length"/>
                    <DoubleProperty name="minRadius" title="the radius of the central cavity" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the truncation radius (zero means no truncation)" displayedIf="Level2" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the truncation height (zero means no truncation)" displayedIf="Level2" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="BrokenExpDiskGeometry" base="SepAxGeometry" title="a broken exponential disk geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="scaleLengthInner" title="the scale length of the inner disk" min="]0" quantity="length"/>
                    <DoubleProperty name="scaleLengthOuter" title="the scale length of the outer disk" min="]0" quantity="length"/>
                    <DoubleProperty name="scaleHeight" title="the scale height" min="]0" quantity="length"/>
                    <DoubleProperty name="breakRadius" title="the break radius" min="]0" quantity="length"/>
                    <DoubleProperty name="sharpness" title="the sharpness of the break" default="3" min="]0"/>
                </properties>
            </Type>
            <Type name="RingGeometry" base="SepAxGeometry" title="a ring geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="ringRadius" title="the radius of the ring" min="]0" quantity="length"/>
                    <DoubleProperty name="width" title="the radial width of the ring" min="]0" quantity="length"/>
                    <DoubleProperty name="height" title="the scale height of the ring" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="TorusGeometry" base="AxGeometry" title="a torus geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="exponent" title="the radial powerlaw exponent p of the torus" min="[0"/>
                    <DoubleProperty name="index" title="the polar index q of the torus" min="[0"/>
                    <DoubleProperty name="openingAngle" title="the half opening angle of the torus" min="[0 deg" max="90 deg]" quantity="posangle"/>
                    <DoubleProperty name="minRadius" title="the minimum radius of the torus" min="]0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the maximum radius of the torus" min="]0" quantity="length"/>
                    <BoolProperty name="reshapeInnerRadius" title="reshape the inner radius according to the Netzer luminosity profile" displayedIf="Level2" default="false"/>
                    <DoubleProperty name="cutoffRadius" title="the inner cutoff radius of the torus" relevantIf="reshapeInnerRadius" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="DonutGeometry" base="AxGeometry" title="a donut torus geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="largeRadius" title="the radius of the torus circle in the equatorial plane" min="]0" quantity="length"/>
                    <DoubleProperty name="smallRadius" title="the radius of the torus circle in the azimuthal plane" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="AnnulusGeometry" base="SepAxGeometry" title="an annulus geometry" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minRadius" title="the inner radius of the annulus" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the outer radius of the annulus" min="]0" quantity="length"/>
                    <DoubleProperty name="height" title="the annulus height" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="TTauriDiskGeometry" base="AxGeometry" title="a T Tauri disk geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="scaleLength" title="the scale length" min="]0" quantity="length"/>
                    <DoubleProperty name="scaleHeight" title="the scale height" min="]0" quantity="length"/>
                    <DoubleProperty name="minRadius" title="the inner radius of the disk" min="]0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the outer radius of the disk" min="]0" quantity="length"/>
                    <DoubleProperty name="radialIndex" title="the radial exponent index α" default="2.5" min="]0"/>
                    <DoubleProperty name="verticalIndex" title="the vertical exponent index b" default="0.5" min="]0"/>
                </properties>
            </Type>
            <Type name="ConicalShellGeometry" base="AxGeometry" title="a conical shell geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="exponent" title="the radial powerlaw exponent p of the conical shell" min="[0"/>
                    <DoubleProperty name="index" title="the polar index q of the conical shell" min="[0"/>
                    <DoubleProperty name="minAngle" title="the inner angle of the conical shell" min="[0 deg" max="90 deg]" quantity="posangle"/>
                    <DoubleProperty name="maxAngle" title="the outer angle of the conical shell" min="[0 deg" max="90 deg]" quantity="posangle"/>
                    <DoubleProperty name="minRadius" title="the minimum radius of the conical shell" min="]0" quantity="length"/>
                    <DoubleProperty name="maxRadius" title="the maximum radius of the conical shell" min="]0" quantity="length"/>
                    <BoolProperty name="reshapeInnerRadius" title="reshape the inner radius according to the Netzer luminosity profile" default="false"/>
                    <DoubleProperty name="cutoffRadius" title="the inner cutoff radius of the conical shell" relevantIf="reshapeInnerRadius" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="ParaboloidGeometry" base="AxGeometry" title="a paraboloid geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="radialExtent" title="the radial extent of the paraboloid" min="]0" quantity="length"/>
                    <DoubleProperty name="openingAngle" title="the half opening angle of the paraboloid" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="offsetZ" title="the offset of the paraboloid vertices in the z direction" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="ParaboloidShellGeometry" base="AxGeometry" title="a paraboloid shell geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="innerRadialExtent" title="the radial extent of the inner paraboloid wall" min="]0" quantity="length"/>
                    <DoubleProperty name="innerOpeningAngle" title="the half opening angle of the inner paraboloid wall" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="outerOpeningAngle" title="the half opening angle of the outer paraboloid wall" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="innerOffsetZ" title="the offset of the inner paraboloid vertices in the z direction" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="outerOffsetZ" title="the offset of the outer paraboloid vertices in the z direction" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="HyperboloidGeometry" base="AxGeometry" title="a hyperboloid geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="radialExtent" title="the radial extent of the hyperboloid" min="]0" quantity="length"/>
                    <DoubleProperty name="openingAngle" title="the half opening angle of the hyperboloid" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="realAxis" title="the real axis of the hyperboloid" min="]0" quantity="length"/>
                    <DoubleProperty name="minRadius" title="the radius of the central cavity" min="]0" quantity="length"/>
                    <BoolProperty name="reshapeInnerRadius" title="reshape the inner radius according to the Netzer luminosity profile" default="false"/>
                    <DoubleProperty name="cutoffRadius" title="the inner cutoff radius of the hyperboloid" relevantIf="reshapeInnerRadius" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="HyperboloidShellGeometry" base="AxGeometry" title="a hyperboloid shell geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="outerRadialExtent" title="the radial extent of the hyperboloid outer wall" min="]0" quantity="length"/>
                    <DoubleProperty name="outerOpeningAngle" title="the half opening angle of the hyperboloid outer wall" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="outerRealAxis" title="the real axis of the hyperboloid outer wall" min="]0" quantity="length"/>
                    <DoubleProperty name="innerOpeningAngle" title="the half opening angle of the hyperboloid inner wall" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="innerRealAxis" title="the real axis of the hyperboloid inner wall" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="MultiGaussianExpansionGeometry" base="AxGeometry" title="a multi-gaussian expansion geometry" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the multi-gaussian expansion parameters"/>
                    <DoubleProperty name="pixelscale" title="the scale of the multi-gaussian-expanded image (length per pixel)" min="]0" quantity="length"/>
                    <DoubleProperty name="inclination" title="the inclination of the system" min="[0" max="90 deg]" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="UniformBoxGeometry" base="GenGeometry" title="a geometry with uniform density inside a box" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the box in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the box in the Z direction" quantity="length"/>
                </properties>
            </Type>
            <Type name="ReadFits3DGeometry" base="GenGeometry" title="a geometry read from a 3D FITS file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the filename of the datacube"/>
                    <DoubleProperty name="pixelScale" title="the pixel scale for the datacube (i.e. the physical length per pixel)" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="ReadFitsGeometry" base="GenGeometry" title="a geometry read from a 2D FITS file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the input image file"/>
                    <DoubleProperty name="pixelScale" title="the physical scale of the image (length per pixel)" min="]0" quantity="length"/>
                    <DoubleProperty name="positionAngle" title="the position angle ω of the system" default="0 deg" min="-360 deg" max="360 deg" quantity="posangle"/>
                    <DoubleProperty name="inclination" title="the inclination angle θ of the system" default="0 deg" min="[0 deg" max="90 deg[" quantity="posangle"/>
                    <IntProperty name="numPixelsX" title="number of pixels in the x direction" min="1"/>
                    <DoubleProperty name="centerX" title="x coordinate of the center (in pixels)" min="]0"/>
                    <IntProperty name="numPixelsY" title="number of pixels in the y direction" min="1"/>
                    <DoubleProperty name="centerY" title="y coordinate of the center (in pixels)" min="]0"/>
                    <DoubleProperty name="scaleHeight" title="the scale height" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="ParticleGeometry" base="ImportedGeometry" title="a geometry imported from smoothed particle data" concrete="true">
                <properties type="Property">
                    <ItemProperty name="smoothingKernel" title="the kernel for interpolating the smoothed particles" displayedIf="Level2" default="CubicSplineSmoothingKernel" base="SmoothingKernel"/>
                </properties>
            </Type>
            <Type name="CellGeometry" base="ImportedGeometry" title="a geometry imported from cuboidal cell data" concrete="true">
                <properties type="Property">
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated mass density)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated number density)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="CylindricalCellGeometry" base="ImportedGeometry" title="a geometry imported from cylindrical cell data" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <BoolProperty name="autoRevolve" title="automatically revolve 2D data to a 3D model" default="false"/>
                    <IntProperty name="numAutoRevolveBins" title="the number of azimuth bins for auto-revolving 2D data" relevantIf="autoRevolve" default="16" min="2" max="1024"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated mass density)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated number density)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SphericalCellGeometry" base="ImportedGeometry" title="a geometry imported from spherical cell data" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="autoRevolve" title="automatically revolve 1D or 2D data to a 3D model" default="None">
                        <enumValues type="EnumValue">
                            <EnumValue name="None" title="no auto-revolve"/>
                            <EnumValue name="Inclination" title="auto-revolve inclination"/>
                            <EnumValue name="Azimuth" title="auto-revolve azimuth"/>
                            <EnumValue name="InclinationAndAzimuth" title="auto-revolve both inclination and azimuth"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numInclinationRevolveBins" title="the number of inclination bins for auto-revolving 1D or 2D data" relevantIf="autoRevolveInclination|autoRevolveInclinationAndAzimuth" default="16" min="2" max="1024"/>
                    <IntProperty name="numAzimuthRevolveBins" title="the number of azimuth bins for auto-revolving 1D or 2D data" relevantIf="autoRevolveAzimuth|autoRevolveInclinationAndAzimuth" default="16" min="2" max="1024"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated mass density)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated number density)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="AdaptiveMeshGeometry" base="MeshGeometry" title="a geometry imported from data represented on an adaptive mesh (AMR grid)" concrete="true" insert="AdaptiveMeshInterface"/>
            <Type name="VoronoiMeshGeometry" base="MeshGeometry" title="a geometry imported from data represented on a Voronoi mesh" concrete="true" insert="VoronoiMeshInterface"/>
            <Type name="OffsetGeometryDecorator" base="Geometry" title="a decorator that adds an offset to any geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry to be offset" base="Geometry"/>
                    <DoubleProperty name="offsetX" title="the offset in the x direction" insert="offsetX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="offsetY" title="the offset in the y direction" insert="offsetY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="offsetZ" title="the offset in the z direction" insert="offsetZ:Dimension2" default="0" quantity="length"/>
                </properties>
            </Type>
            <Type name="RotateGeometryDecorator" base="GenGeometry" title="a decorator that adds a rotation to any geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry to be rotated" base="Geometry"/>
                    <DoubleProperty name="eulerAlpha" title="the first Euler angle α" default="0 deg" min="0 deg" max="360 deg" quantity="posangle"/>
                    <DoubleProperty name="eulerBeta" title="the second Euler angle β" default="0 deg" min="0 deg" max="180 deg" quantity="posangle"/>
                    <DoubleProperty name="eulerGamma" title="the third Euler angle γ" default="0 deg" min="0 deg" max="360 deg" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="SpheroidalGeometryDecorator" base="AxGeometry" title="a decorator that constructs a spheroidal variant of any spherical geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the spherical geometry to be made spheroidal" base="SpheGeometry"/>
                    <DoubleProperty name="flattening" title="the flattening parameter q" default="1" min="]0"/>
                </properties>
            </Type>
            <Type name="TriaxialGeometryDecorator" base="GenGeometry" title="a decorator that constructs a triaxial variant of any spherical geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the spherical geometry to be made triaxial" base="SpheGeometry"/>
                    <DoubleProperty name="flatteningY" title="the flattening parameter p (along the y-axis)" default="1" min="]0"/>
                    <DoubleProperty name="flatteningZ" title="the flattening parameter q (along the z-axis)" default="1" min="]0"/>
                </properties>
            </Type>
            <Type name="SphericalClipGeometryDecorator" base="ClipGeometryDecorator" title="a decorator that clips another geometry using a sphere" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="clipRadius" title="the radius of the clipping sphere" min="[0" quantity="length"/>
                    <DoubleProperty name="centerX" title="the x coordinate of the sphere&apos;s center" displayedIf="Level2" insert="centerX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="centerY" title="the y coordinate of the sphere&apos;s center" displayedIf="Level2" insert="centerY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="centerZ" title="the z coordinate of the sphere&apos;s center" displayedIf="Level2" insert="centerZ:Dimension2" default="0" quantity="length"/>
                </properties>
            </Type>
            <Type name="CylindricalClipGeometryDecorator" base="ClipGeometryDecorator" title="a decorator that clips another geometry using a cylinder" concrete="true" insert="Dimension2">
                <properties type="Property">
                    <DoubleProperty name="clipRadius" title="the radius of the clipping cylinder" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="BoxClipGeometryDecorator" base="ClipGeometryDecorator" title="a decorator that clips another geometry using a cubodial box" concrete="true" insert="Dimension3">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the box in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the box in the Z direction" quantity="length"/>
                </properties>
            </Type>
            <Type name="SpiralStructureGeometryDecorator" base="GenGeometry" title="a decorator that adds spiral structure to any axisymmetric geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the axisymmetric geometry to be decorated with spiral structure" base="AxGeometry"/>
                    <IntProperty name="numArms" title="the number of spiral arms" default="1" min="1" max="100"/>
                    <DoubleProperty name="pitchAngle" title="the pitch angle" default="10 deg" min="]0 deg" max="90 deg[" quantity="posangle"/>
                    <DoubleProperty name="radiusZeroPoint" title="the radius zero-point" min="]0" quantity="length"/>
                    <DoubleProperty name="phaseZeroPoint" title="the phase zero-point" displayedIf="Level2" default="0 deg" min="[0 deg" max="360 deg]" quantity="posangle"/>
                    <DoubleProperty name="perturbationWeight" title="the weight of the spiral perturbation" min="]0" max="1]"/>
                    <IntProperty name="index" title="the arm-interarm size ratio index" displayedIf="Level2" default="1" min="0" max="10"/>
                </properties>
            </Type>
            <Type name="ClumpyGeometryDecorator" base="GenGeometry" title="a decorator that adds clumpiness to any geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry to be made clumpy" base="Geometry"/>
                    <DoubleProperty name="clumpFraction" title="the fraction of the mass locked up in clumps" min="[0" max="1]"/>
                    <IntProperty name="numClumps" title="the total number of clumps" min="1"/>
                    <DoubleProperty name="clumpRadius" title="the scale radius of a single clump" min="]0" quantity="length"/>
                    <BoolProperty name="cutoffClumps" title="cut off clumps at the boundary of the underlying geometry" displayedIf="Level2" default="false"/>
                    <ItemProperty name="smoothingKernel" title="the smoothing kernel that describes the density of a single clump" displayedIf="Level2" default="CubicSplineSmoothingKernel" base="SmoothingKernel"/>
                    <IntProperty name="seed" title="the seed for the random clump position generator, or zero to use the default generator" displayedIf="Level3" default="0" min="0" max="1000000"/>
                </properties>
            </Type>
            <Type name="CombineGeometryDecorator" base="Geometry" title="a decorator that combines two different geometries" concrete="true">
                <properties type="Property">
                    <ItemProperty name="firstGeometry" title="the first geometry" base="Geometry"/>
                    <DoubleProperty name="firstWeight" title="the weight of the first geometry" default="1" min="]0"/>
                    <ItemProperty name="secondGeometry" title="the second geometry" base="Geometry"/>
                    <DoubleProperty name="secondWeight" title="the weight of the second geometry" default="1" min="]0"/>
                </properties>
            </Type>
            <Type name="AxPowerLawRedistributeGeometryDecorator" base="RedistributeGeometryDecorator" title="a decorator that redistributes another geometry with an axial power law" concrete="true" insert="Dimension2">
                <properties type="Property">
                    <DoubleProperty name="RExponent" title="the negative power of the radial part of the weight function" min="[0"/>
                    <DoubleProperty name="zExponent" title="the negative power of the vertical part of the weight function" min="[0"/>
                    <DoubleProperty name="minR" title="the radius of the clipping cylinder around the z-axis" relevantIf="RExponent" min="[0 pc" quantity="length"/>
                    <DoubleProperty name="minZ" title="half the height of the clipping region around the xy-plane" relevantIf="zExponent" min="[0 pc" quantity="length"/>
                </properties>
            </Type>
            <Type name="SphePowerLawRedistributeGeometryDecorator" base="RedistributeGeometryDecorator" title="a decorator that redistributes another geometry with a spherical power law" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="exponent" title="the negative power of the weight function" min="]0"/>
                    <DoubleProperty name="minRadius" title="the radius of the clipping sphere" min="]0 pc" quantity="length"/>
                </properties>
            </Type>
            <Type name="CubicSplineSmoothingKernel" base="SmoothingKernel" title="a cubic spline smoothing kernel" concrete="true"/>
            <Type name="QuarticSplineSmoothingKernel" base="SmoothingKernel" title="a quartic spline smoothing kernel" concrete="true"/>
            <Type name="ScaledGaussianSmoothingKernel" base="SmoothingKernel" title="a scaled Gaussian smoothing kernel" concrete="true"/>
            <Type name="UniformSmoothingKernel" base="SmoothingKernel" title="a uniform smoothing kernel" concrete="true"/>
            <Type name="RadialVectorField" base="VectorField" title="a vector field pointing away from the origin" concrete="true" insert="Dimension3">
                <properties type="Property">
                    <DoubleProperty name="unityRadius" title="the radius where the magnitude of the vectors is unity" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="exponent" title="the power-law exponent governing the radial dependence of the magnitude" default="1"/>
                </properties>
            </Type>
            <Type name="HollowRadialVectorField" base="VectorField" title="a vector field pointing away from the origin with a central cavity" concrete="true" insert="Dimension3">
                <properties type="Property">
                    <DoubleProperty name="zeroRadius" title="the radius within which the magnitude of the vectors is zero" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="exponent" title="the power-law exponent governing the radial dependence of the magnitude" default="0" min="[0"/>
                </properties>
            </Type>
            <Type name="CylindricalVectorField" base="VectorField" title="a vector field rotating clockwise around the z-axis" concrete="true" insert="Dimension3">
                <properties type="Property">
                    <DoubleProperty name="unityRadius" title="the radius where the magnitude of the vectors is unity" default="0" min="[0" quantity="length"/>
                    <DoubleProperty name="exponent" title="the power-law exponent governing the radial dependence of the magnitude" default="1"/>
                </properties>
            </Type>
            <Type name="UnidirectionalVectorField" base="VectorField" title="a vector field uniformly pointing in a given direction" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="fieldX" title="the field direction, x component" insert="fieldX:Dimension3" default="0"/>
                    <DoubleProperty name="fieldY" title="the field direction, y component" insert="fieldY:Dimension3" default="0"/>
                    <DoubleProperty name="fieldZ" title="the field direction, z component" insert="fieldZ:Dimension2" default="1"/>
                </properties>
            </Type>
            <Type name="OffsetVectorFieldDecorator" base="VectorField" title="a decorator that adds an offset to any vector field" concrete="true">
                <properties type="Property">
                    <ItemProperty name="vectorField" title="the vector field to be offset" base="VectorField"/>
                    <DoubleProperty name="offsetX" title="the offset in the x direction" insert="offsetX:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="offsetY" title="the offset in the y direction" insert="offsetY:Dimension3" default="0" quantity="length"/>
                    <DoubleProperty name="offsetZ" title="the offset in the z direction" insert="offsetZ:Dimension2" default="0" quantity="length"/>
                </properties>
            </Type>
            <Type name="RotateVectorFieldDecorator" base="VectorField" title="a decorator that adds a rotation to any vector field" concrete="true" insert="Dimension3">
                <properties type="Property">
                    <ItemProperty name="vectorField" title="the vector field to be rotated" base="VectorField"/>
                    <DoubleProperty name="eulerAlpha" title="the first Euler angle α" default="0 deg" min="0 deg" max="360 deg" quantity="posangle"/>
                    <DoubleProperty name="eulerBeta" title="the second Euler angle β" default="0 deg" min="0 deg" max="180 deg" quantity="posangle"/>
                    <DoubleProperty name="eulerGamma" title="the third Euler angle γ" default="0 deg" min="0 deg" max="360 deg" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="Sphere1DSpatialGrid" base="SphereSpatialGrid" title="a 1D spherically symmetric spatial grid" concrete="true" allowedIf="!Dimension2&amp;!Dimension3">
                <properties type="Property">
                    <ItemProperty name="meshRadial" title="the bin distribution in the radial direction" default="LinMesh" base="Mesh"/>
                </properties>
            </Type>
            <Type name="Sphere2DSpatialGrid" base="SphereSpatialGrid" title="a 2D axisymmetric spatial grid in spherical coordinates" concrete="true" allowedIf="!Dimension3" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="meshRadial" title="the bin distribution in the radial direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshPolar" title="the bin distribution in the polar direction" default="LinMesh" base="Mesh"/>
                </properties>
            </Type>
            <Type name="Cylinder2DSpatialGrid" base="CylinderSpatialGrid" title="a 2D axisymmetric spatial grid in cylindrical coordinates" concrete="true" allowedIf="!Dimension3">
                <properties type="Property">
                    <ItemProperty name="meshRadial" title="the bin distribution in the radial direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshZ" title="the bin distribution in the Z direction" default="LinMesh" base="Mesh"/>
                </properties>
            </Type>
            <Type name="Sphere3DSpatialGrid" base="SphereSpatialGrid" title="a 3D spatial grid in spherical coordinates" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="meshRadial" title="the bin distribution in the radial direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshPolar" title="the bin distribution in the polar direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshAzimuthal" title="the bin distribution in the azimuthal direction" default="LinMesh" base="Mesh"/>
                </properties>
            </Type>
            <Type name="Cylinder3DSpatialGrid" base="CylinderSpatialGrid" title="a 3D spatial grid in cylindrical coordinates" concrete="true">
                <properties type="Property">
                    <ItemProperty name="meshRadial" title="the bin distribution in the radial direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshAzimuthal" title="the bin distribution in the azimuthal direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshZ" title="the bin distribution in the vertical direction" default="LinMesh" base="Mesh"/>
                </properties>
            </Type>
            <Type name="CartesianSpatialGrid" base="BoxSpatialGrid" title="a Cartesian spatial grid" concrete="true">
                <properties type="Property">
                    <ItemProperty name="meshX" title="the bin distribution in the X direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshY" title="the bin distribution in the Y direction" default="LinMesh" base="Mesh"/>
                    <ItemProperty name="meshZ" title="the bin distribution in the Z direction" default="LinMesh" base="Mesh"/>
                </properties>
            </Type>
            <Type name="PolicyTreeSpatialGrid" base="TreeSpatialGrid" title="a tree-based spatial grid" concrete="true">
                <properties type="Property">
                    <EnumProperty name="treeType" title="the type of tree" displayedIf="Level2" insert="treeTypeOctTree:OctTreeGrid;treeTypeBinTree:BinTreeGrid" default="OctTree">
                        <enumValues type="EnumValue">
                            <EnumValue name="OctTree" title="an octtree (8 children per node)"/>
                            <EnumValue name="BinTree" title="a binary tree (2 children per node)"/>
                        </enumValues>
                    </EnumProperty>
                    <ItemProperty name="policy" title="the tree construction policy (configuration options)" default="DensityTreePolicy" base="TreePolicy"/>
                </properties>
            </Type>
            <Type name="FileTreeSpatialGrid" base="TreeSpatialGrid" title="a tree-based spatial grid loaded from a topology data file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the tree topology data"/>
                </properties>
            </Type>
            <Type name="AdaptiveMeshSpatialGrid" base="SpatialGrid" title="a spatial grid taken from an imported adaptive mesh snapshot" concrete="true" allowedIf="AdaptiveMeshInterface" displayedIf="Level2"/>
            <Type name="VoronoiMeshSpatialGrid" base="BoxSpatialGrid" title="a Voronoi tessellation-based spatial grid" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="policy" title="the policy for determining the positions of the sites" default="DustDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="Uniform" title="random from uniform distribution"/>
                            <EnumValue name="CentralPeak" title="random from distribution with a steep central peak"/>
                            <EnumValue name="DustDensity" title="random from dust density distribution"/>
                            <EnumValue name="ElectronDensity" title="random from electron density distribution"/>
                            <EnumValue name="GasDensity" title="random from gas density distribution"/>
                            <EnumValue name="File" title="loaded from text column data file"/>
                            <EnumValue name="ImportedSites" title="positions of particles, sites or cells in imported distribution"/>
                            <EnumValue name="ImportedMesh" title="employ imported Voronoi mesh in medium system"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numSites" title="the number of random sites (or cells in the grid)" relevantIf="policyUniform|policyCentralPeak|policyDustDensity|policyElectronDensity|policyGasDensity" default="500" min="5"/>
                    <StringProperty name="filename" title="the name of the file containing the site positions" relevantIf="policyFile"/>
                    <BoolProperty name="relaxSites" title="perform site relaxation to avoid overly elongated cells" relevantIf="!policyImportedMesh" default="false"/>
                </properties>
            </Type>
            <Type name="TetraMeshSpatialGrid" base="BoxSpatialGrid" title="a tetrahedral spatial grid" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="policy" title="the policy for determining the positions of the vertices" default="DustDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="Uniform" title="random from uniform distribution"/>
                            <EnumValue name="CentralPeak" title="random from distribution with a steep central peak"/>
                            <EnumValue name="DustDensity" title="random from dust density distribution"/>
                            <EnumValue name="ElectronDensity" title="random from electron density distribution"/>
                            <EnumValue name="GasDensity" title="random from gas density distribution"/>
                            <EnumValue name="File" title="loaded from text column data file"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numSamples" title="the number of random positions to be used as vertices" relevantIf="policyUniform|policyCentralPeak|policyDustDensity|policyElectronDensity|policyGasDensity" default="500" min="4"/>
                    <StringProperty name="filename" title="the name of the file containing the vertex positions" relevantIf="policyFile"/>
                    <BoolProperty name="refine" title="refine the grid by performing local mesh operations" default="false"/>
                </properties>
            </Type>
            <Type name="DensityTreePolicy" base="TreePolicy" title="a tree grid construction policy using the medium density distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="maxDustFraction" title="the maximum fraction of dust contained in each cell" displayedIf="DustMix" default="1e-6" min="[0" max="1e-2]"/>
                    <DoubleProperty name="maxDustOpticalDepth" title="the maximum diagonal dust optical depth for each cell" displayedIf="DustMix&amp;Level2" default="0" min="[0" max="100]"/>
                    <DoubleProperty name="wavelength" title="the wavelength at which to evaluate the optical depth" relevantIf="maxDustOpticalDepth" default="0.55 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxDustDensityDispersion" title="the maximum dust density dispersion in each cell" displayedIf="DustMix&amp;Level2" default="0" min="[0" max="1]"/>
                    <DoubleProperty name="maxElectronFraction" title="the maximum fraction of electrons contained in each cell" displayedIf="ElectronMix" default="1e-6" min="[0" max="1e-2]"/>
                    <DoubleProperty name="maxGasFraction" title="the maximum fraction of gas contained in each cell" displayedIf="GasMix" default="1e-6" min="[0" max="1e-2]"/>
                </properties>
            </Type>
            <Type name="NestedDensityTreePolicy" base="DensityTreePolicy" title="a tree grid construction policy using a nested density tree policy" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="innerMinX" title="the start point of the inner box in the X direction" quantity="length"/>
                    <DoubleProperty name="innerMaxX" title="the end point of the inner box in the X direction" quantity="length"/>
                    <DoubleProperty name="innerMinY" title="the start point of the inner box in the Y direction" quantity="length"/>
                    <DoubleProperty name="innerMaxY" title="the end point of the inner box in the Y direction" quantity="length"/>
                    <DoubleProperty name="innerMinZ" title="the start point of the inner box in the Z direction" quantity="length"/>
                    <DoubleProperty name="innerMaxZ" title="the end point of the inner box in the Z direction" quantity="length"/>
                    <ItemProperty name="innerPolicy" title="the density tree policy for the inner region" default="DensityTreePolicy" base="DensityTreePolicy"/>
                </properties>
            </Type>
            <Type name="SiteListTreePolicy" base="TreePolicy" title="a tree grid construction policy using positions defined by an imported medium" concrete="true" allowedIf="SiteListInterface" displayedIf="Level2">
                <properties type="Property">
                    <IntProperty name="numExtraLevels" title="the number of additional subdivision levels" default="0" min="0" max="30"/>
                </properties>
            </Type>
            <Type name="LinMesh" base="Mesh" title="a linear mesh" concrete="true"/>
            <Type name="PowMesh" base="Mesh" title="a power-law mesh" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="ratio" title="the bin width ratio between the last and the first bin" default="1" min="]0"/>
                </properties>
            </Type>
            <Type name="SymPowMesh" base="Mesh" title="a symmetric power-law mesh" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="ratio" title="the bin width ratio between the outermost and the innermost bins" default="1" min="]0"/>
                </properties>
            </Type>
            <Type name="LogMesh" base="Mesh" title="a logarithmic mesh" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="centralBinFraction" title="the central bin width fraction" default="1e-3" min="]0" max="1["/>
                </properties>
            </Type>
            <Type name="SymLogMesh" base="Mesh" title="a symmetric logarithmic mesh" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="centralBinFraction" title="the central bin width fraction" default="1e-3" min="]0" max="1["/>
                </properties>
            </Type>
            <Type name="SymCosMesh" base="Mesh" title="a symmetric cosine mesh" concrete="true"/>
            <Type name="FileMesh" base="TabulatedMesh" title="a mesh read from a file" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the mesh border points"/>
                </properties>
            </Type>
            <Type name="ListMesh" base="TabulatedMesh" title="a mesh specified inside the configuration file" concrete="true">
                <properties type="Property">
                    <DoubleListProperty name="points" title="the mesh border points" min="[0"/>
                </properties>
            </Type>
            <Type name="MediumSystem" base="SimulationItem" title="a medium system" concrete="true" allowedIf="!NoMedium">
                <properties type="Property">
                    <ItemProperty name="photonPacketOptions" title="the photon packet options" relevantIf="!NoMedium" default="PhotonPacketOptions" base="PhotonPacketOptions"/>
                    <ItemProperty name="lyaOptions" title="the Lyman-alpha line transfer options" relevantIf="Lya" default="LyaOptions" base="LyaOptions"/>
                    <ItemProperty name="dynamicStateOptions" title="the dynamic medium state options" relevantIf="IteratePrimary" default="DynamicStateOptions" base="DynamicStateOptions"/>
                    <ItemProperty name="radiationFieldOptions" title="the radiation field options" relevantIf="!NoMedium" default="RadiationFieldOptions" base="RadiationFieldOptions"/>
                    <ItemProperty name="secondaryEmissionOptions" title="the secondary emission options" relevantIf="Emission" default="SecondaryEmissionOptions" base="SecondaryEmissionOptions"/>
                    <ItemProperty name="iterationOptions" title="the primary and/or secondary emission iteration options" relevantIf="IteratePrimary|IterateSecondary" default="IterationOptions" base="IterationOptions"/>
                    <ItemProperty name="dustEmissionOptions" title="the dust emission options" relevantIf="DustEmission" default="DustEmissionOptions" base="DustEmissionOptions"/>
                    <ItemListProperty name="media" title="the transfer media" requiredIf="!NoMedium" default="GeometricMedium" base="Medium"/>
                    <ItemProperty name="samplingOptions" title="the spatial grid sampling options" default="SamplingOptions" base="SamplingOptions"/>
                    <ItemProperty name="grid" title="the spatial grid" default="Dimension3:PolicyTreeSpatialGrid;Dimension2:Cylinder2DSpatialGrid;Sphere1DSpatialGrid" base="SpatialGrid"/>
                </properties>
            </Type>
            <Type name="GeometricMedium" base="Medium" title="a transfer medium with a built-in geometry" concrete="true">
                <properties type="Property">
                    <ItemProperty name="geometry" title="the geometry of the spatial density distribution for the medium" default="PlummerGeometry" base="Geometry"/>
                    <ItemProperty name="materialMix" title="the material type and properties throughout the medium" default="MeanInterstellarDustMix" base="MaterialMix"/>
                    <ItemProperty name="normalization" title="the type of normalization for the amount of material" default="OpticalDepthMaterialNormalization" base="MaterialNormalization"/>
                    <ItemProperty name="velocityDistribution" title="the spatial distribution of the velocity, if any" relevantIf="Panchromatic" displayedIf="Level2" requiredIf="false" base="VectorField"/>
                    <DoubleProperty name="velocityMagnitude" title="the magnitude of the velocity (multiplier)" relevantIf="Panchromatic&amp;velocityDistribution" displayedIf="Level2" insert="velocityDistribution&amp;velocityMagnitude:MediumVelocity" min="[-100000 km/s" max="100000 km/s]" quantity="velocity"/>
                    <ItemProperty name="magneticFieldDistribution" title="the spatial distribution of the magnetic field, if any" displayedIf="Level3" requiredIf="false" base="VectorField"/>
                    <DoubleProperty name="magneticFieldStrength" title="the strength of the magnetic field  (multiplier)" relevantIf="magneticFieldDistribution" displayedIf="Level3" insert="magneticFieldDistribution&amp;magneticFieldStrength:MagneticField" min="[-1 T" max="1 T]" quantity="magneticfield"/>
                </properties>
            </Type>
            <Type name="ParticleMedium" base="ImportedMedium" title="a transfer medium imported from smoothed particle data" concrete="true">
                <properties type="Property">
                    <ItemProperty name="smoothingKernel" title="the kernel for interpolating the smoothed particles" displayedIf="Level2" default="CubicSplineSmoothingKernel" base="SmoothingKernel"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="Mass">
                        <enumValues type="EnumValue">
                            <EnumValue name="Mass" title="mass (volume-integrated)"/>
                            <EnumValue name="Number" title="number (volume-integrated)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="CellMedium" base="ImportedMedium" title="a transfer medium imported from cuboidal cell data" concrete="true">
                <properties type="Property">
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="CylindricalCellMedium" base="ImportedMedium" title="a transfer medium imported from cylindrical cell data" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <BoolProperty name="autoRevolve" title="automatically revolve 2D data to a 3D model" default="false"/>
                    <IntProperty name="numAutoRevolveBins" title="the number of azimuth bins for auto-revolving 2D data" relevantIf="autoRevolve" default="16" min="2" max="1024"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SphericalCellMedium" base="ImportedMedium" title="a transfer medium imported from spherical cell data" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="autoRevolve" title="automatically revolve 1D or 2D data to a 3D model" default="None">
                        <enumValues type="EnumValue">
                            <EnumValue name="None" title="no auto-revolve"/>
                            <EnumValue name="Inclination" title="auto-revolve inclination"/>
                            <EnumValue name="Azimuth" title="auto-revolve azimuth"/>
                            <EnumValue name="InclinationAndAzimuth" title="auto-revolve both inclination and azimuth"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numInclinationRevolveBins" title="the number of inclination bins for auto-revolving 1D or 2D data" relevantIf="autoRevolveInclination|autoRevolveInclinationAndAzimuth" default="16" min="2" max="1024"/>
                    <IntProperty name="numAzimuthRevolveBins" title="the number of azimuth bins for auto-revolving 1D or 2D data" relevantIf="autoRevolveAzimuth|autoRevolveInclinationAndAzimuth" default="16" min="2" max="1024"/>
                    <EnumProperty name="massType" title="the type of mass quantity to be imported" default="MassDensity">
                        <enumValues type="EnumValue">
                            <EnumValue name="MassDensity" title="mass density"/>
                            <EnumValue name="Mass" title="mass (volume-integrated)"/>
                            <EnumValue name="NumberDensity" title="number density"/>
                            <EnumValue name="Number" title="number (volume-integrated)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="AdaptiveMeshMedium" base="MeshMedium" title="a transfer medium imported from data represented on an adaptive mesh (AMR grid)" concrete="true" insert="AdaptiveMeshInterface"/>
            <Type name="VoronoiMeshMedium" base="MeshMedium" title="a transfer medium imported from data represented on a Voronoi mesh" concrete="true" insert="VoronoiMeshInterface"/>
            <Type name="PhotonPacketOptions" base="SimulationItem" title="a set of options related to the photon packet lifecycle" concrete="true">
                <properties type="Property">
                    <BoolProperty name="explicitAbsorption" title="use explicit absorption to allow negative absorption (stimulated emission)" displayedIf="Level3" default="false"/>
                    <BoolProperty name="forceScattering" title="use forced scattering to reduce noise" relevantIf="!(Emission|IteratePrimary)" displayedIf="Level3" insert="Emission|IteratePrimary|forceScattering:ForceScattering" default="Lya:false;true"/>
                    <DoubleProperty name="minWeightReduction" title="the minimum weight reduction factor before a photon packet is terminated" relevantIf="ForceScattering" displayedIf="Level3" default="1e4" min="[1e3"/>
                    <IntProperty name="minScattEvents" title="the minimum number of forced scattering events before a photon packet is terminated" relevantIf="ForceScattering" displayedIf="Level3" default="0" min="0" max="1000"/>
                    <DoubleProperty name="pathLengthBias" title="the fraction of path lengths sampled from a stretched distribution" relevantIf="(ForceScattering)&amp;(!Lya)" displayedIf="Level3" default="(ForceScattering)&amp;(!Lya):0.5;0" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="LyaOptions" base="SimulationItem" title="a set of options related to Lyman-alpha line transfer" concrete="true">
                <properties type="Property">
                    <EnumProperty name="lyaAccelerationScheme" title="the Lyman-alpha line transfer acceleration scheme" displayedIf="Level2" default="Variable">
                        <enumValues type="EnumValue">
                            <EnumValue name="None" title="no acceleration"/>
                            <EnumValue name="Constant" title="acceleration scheme with a constant critical value"/>
                            <EnumValue name="Variable" title="acceleration scheme depending on local gas temperature and density"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="lyaAccelerationStrength" title="the acceleration strength; higher is faster but less accurate" relevantIf="lyaAccelerationSchemeConstant|lyaAccelerationSchemeVariable" displayedIf="Level2" default="1" min="]0" max="10]"/>
                    <BoolProperty name="includeHubbleFlow" title="include the Doppler shift caused by the expansion of the universe" displayedIf="Level2" default="false"/>
                </properties>
            </Type>
            <Type name="DynamicStateOptions" base="SimulationItem" title="a set of options for dynamically adjusting the medium state" concrete="true">
                <properties type="Property">
                    <ItemListProperty name="recipes" title="the dynamic medium state recipes" relevantIf="IteratePrimary|IterateSecondary" requiredIf="false" insert="DynamicState" base="DynamicStateRecipe"/>
                </properties>
            </Type>
            <Type name="RadiationFieldOptions" base="SimulationItem" title="a set of options related to the radiation field" concrete="true">
                <properties type="Property">
                    <BoolProperty name="storeRadiationField" title="store the radiation field so that it can be probed for output" relevantIf="!Emission&amp;!IteratePrimary&amp;ForceScattering" displayedIf="Level3" insert="!Emission&amp;!IteratePrimary&amp;ForceScattering&amp;storeRadiationField:RadiationField" default="Emission|IteratePrimary:true;false"/>
                    <ItemProperty name="radiationFieldWLG" title="the wavelength grid for storing the radiation field" relevantIf="RadiationField&amp;Panchromatic" default="LogWavelengthGrid" base="DisjointWavelengthGrid"/>
                </properties>
            </Type>
            <Type name="SecondaryEmissionOptions" base="SimulationItem" title="a set of options related to secondary emission" concrete="true">
                <properties type="Property">
                    <BoolProperty name="storeEmissionRadiationField" title="store the radiation field during emission so that it can be probed for output" displayedIf="Level3" default="false"/>
                    <DoubleProperty name="secondaryPacketsMultiplier" title="the multiplier on the number of photon packets launched for secondary emission" displayedIf="Level3" default="1" min="]0" max="1000]"/>
                    <DoubleProperty name="spatialBias" title="the fraction of secondary photon packets distributed uniformly across spatial cells" displayedIf="Level3" default="0.5" min="[0" max="1]"/>
                    <DoubleProperty name="sourceBias" title="the fraction of photon packets distributed uniformly across secondary sources" displayedIf="Level3" default="0.5" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="IterationOptions" base="SimulationItem" title="a set of options for configuring iterations during primary and/or secondary emission" concrete="true">
                <properties type="Property">
                    <IntProperty name="minPrimaryIterations" title="the minimum number of iterations during primary emission" relevantIf="IteratePrimary" default="1" min="1" max="1000"/>
                    <IntProperty name="maxPrimaryIterations" title="the maximum number of iterations during primary emission" relevantIf="IteratePrimary" default="10" min="1" max="1000"/>
                    <IntProperty name="minSecondaryIterations" title="the minimum number of iterations during secondary emission" relevantIf="IterateSecondary" default="1" min="1" max="1000"/>
                    <IntProperty name="maxSecondaryIterations" title="the maximum number of iterations during secondary emission" relevantIf="IterateSecondary" default="10" min="0" max="1000"/>
                    <BoolProperty name="includePrimaryEmission" title="include primary emission in the secondary emission iterations" relevantIf="IterateSecondary" displayedIf="Level3" default="false"/>
                    <DoubleProperty name="primaryIterationPacketsMultiplier" title="the multiplier on the number of photon packets launched for each primary emission iteration" relevantIf="IteratePrimary|includePrimaryEmission" displayedIf="Level3" default="1" min="]0" max="1000]"/>
                    <DoubleProperty name="secondaryIterationPacketsMultiplier" title="the multiplier on the number of photon packets launched for each secondary emission iteration" relevantIf="IterateSecondary" displayedIf="Level3" default="1" min="]0" max="1000]"/>
                </properties>
            </Type>
            <Type name="DustEmissionOptions" base="SimulationItem" title="a set of options related to thermal emission from dust" concrete="true">
                <properties type="Property">
                    <EnumProperty name="dustEmissionType" title="the method used for dust emission calculations" displayedIf="Level2" insert="dustEmissionTypeStochastic:StochasticDustEmission" default="Equilibrium">
                        <enumValues type="EnumValue">
                            <EnumValue name="Equilibrium" title="assume local thermal equilibrium (LTE)"/>
                            <EnumValue name="Stochastic" title="handle stochastically heated grains (non-LTE)"/>
                        </enumValues>
                    </EnumProperty>
                    <BoolProperty name="includeHeatingByCMB" title="add the cosmic microwave background (CMB) as a dust heating source term" displayedIf="NonZeroRedshift" default="false"/>
                    <ItemProperty name="cellLibrary" title="the spatial cell grouping scheme for calculating dust emission" displayedIf="Level2" requiredIf="false" default="AllCellsLibrary" base="SpatialCellLibrary"/>
                    <ItemProperty name="dustEmissionWLG" title="the wavelength grid for calculating the dust emission spectrum" default="LogWavelengthGrid" base="DisjointWavelengthGrid"/>
                    <DoubleProperty name="maxFractionOfPrimary" title="convergence is reached when the total absorbed dust luminosity is less than this fraction of the total absorbed primary luminosity" relevantIf="IterateSecondary" default="0.01" min="]0" max="1["/>
                    <DoubleProperty name="maxFractionOfPrevious" title="convergence is reached when the total absorbed dust luminosity has changed by less than this fraction compared to the previous iteration" relevantIf="IterateSecondary" default="0.03" min="]0" max="1["/>
                    <DoubleProperty name="sourceWeight" title="the weight of dust emission for the number of photon packets launched" displayedIf="Level3" default="1" min="]0" max="1000]"/>
                    <DoubleProperty name="wavelengthBias" title="the fraction of secondary photon packet wavelengths sampled from a bias distribution" displayedIf="Level3" default="0.5" min="[0" max="1]"/>
                    <ItemProperty name="wavelengthBiasDistribution" title="the bias distribution for sampling secondary photon packet wavelengths" relevantIf="wavelengthBias" displayedIf="Level3" default="DefaultWavelengthDistribution" base="WavelengthDistribution"/>
                </properties>
            </Type>
            <Type name="SamplingOptions" base="SimulationItem" title="a set of options related to media sampling for the spatial grid" concrete="true">
                <properties type="Property">
                    <IntProperty name="numDensitySamples" title="the number of random density samples for determining spatial cell mass" displayedIf="Level2" default="100" min="1" max="10000"/>
                    <IntProperty name="numPropertySamples" title="the number of random samples for determining other medium properties" displayedIf="Level3" default="1" min="1" max="10000"/>
                    <EnumProperty name="aggregateVelocity" title="aggregating the bulk velocity from multiple medium components" relevantIf="MediumVelocity" default="Average">
                        <enumValues type="EnumValue">
                            <EnumValue name="Average" title="Use the density-weighted average; missing values are taken to be zero"/>
                            <EnumValue name="Maximum" title="Use the vector with largest magnitude; missing values are taken to be zero"/>
                            <EnumValue name="First" title="Use the vector of the first medium component for which one is available"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MassMaterialNormalization" base="MaterialNormalization" title="normalization by defining the total mass" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="mass" title="the total mass of the material" min="]0" quantity="mass"/>
                </properties>
            </Type>
            <Type name="NumberMaterialNormalization" base="MaterialNormalization" title="normalization by defining the total number of entities" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="number" title="the total number of entities in the material" min="]0"/>
                </properties>
            </Type>
            <Type name="OpticalDepthMaterialNormalization" base="AxisMaterialNormalization" title="normalization by defining the optical depth along a coordinate axis" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="wavelength" title="the wavelength at which to specify the optical depth" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="opticalDepth" title="the optical depth along this axis at this wavelength" min="]0"/>
                </properties>
            </Type>
            <Type name="MassColumnMaterialNormalization" base="AxisMaterialNormalization" title="normalization by defining the mass column density along a coordinate axis" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="massColumnDensity" title="the mass column density along this axis" min="]0" quantity="masssurfacedensity"/>
                </properties>
            </Type>
            <Type name="NumberColumnMaterialNormalization" base="AxisMaterialNormalization" title="normalization by defining the number column density along a coordinate axis" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="numberColumnDensity" title="the number column density along this axis" min="]0" quantity="numbersurfacedensity"/>
                </properties>
            </Type>
            <Type name="MeanInterstellarDustMix" base="SingleGrainDustMix" title="a typical interstellar dust mix (mean properties)" concrete="true"/>
            <Type name="MeanTrustBenchmarkDustMix" base="SingleGrainDustMix" title="a TRUST benchmark dust mix (mean properties, optionally with polarization)" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="scatteringType" title="the type of scattering to be implemented" default="HenyeyGreenstein">
                        <enumValues type="EnumValue">
                            <EnumValue name="HenyeyGreenstein" title="use the Henyey-Greenstein phase function (unpolarized)"/>
                            <EnumValue name="MaterialPhaseFunction" title="use the phase function derived from actual material properties (unpolarized)"/>
                            <EnumValue name="SphericalPolarization" title="support polarization through scattering by spherical grains"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MeanPinteBenchmarkDustMix" base="SingleGrainDustMix" title="a Pinte 2D benchmark dust mix (mean properties, optionally with polarization at 1 micron)" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="scatteringType" title="the type of scattering to be implemented" default="HenyeyGreenstein">
                        <enumValues type="EnumValue">
                            <EnumValue name="HenyeyGreenstein" title="use the Henyey-Greenstein phase function (unpolarized)"/>
                            <EnumValue name="MaterialPhaseFunction" title="use the phase function derived from actual material properties (unpolarized)"/>
                            <EnumValue name="SphericalPolarization" title="support polarization through scattering by spherical grains"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MeanPascucciBenchmarkDustMix" base="SingleGrainDustMix" title="a Pascucci 2D benchmark dust mix (mean properties)" concrete="true" displayedIf="Level2"/>
            <Type name="MeanIvezicBenchmarkDustMix" base="SingleGrainDustMix" title="an Ivezic 1D benchmark dust mix (mean properties)" concrete="true" displayedIf="Level2"/>
            <Type name="MeanFileDustMix" base="TabulatedDustMix" title="a dust mix with mean properties loaded from a text file" concrete="true">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the optical properties for the dust mix"/>
                </properties>
            </Type>
            <Type name="MeanListDustMix" base="TabulatedDustMix" title="a dust mix with mean properties specified inside the configuration file" concrete="true">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the wavelengths at which to specify the optical properties" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleListProperty name="extinctionCoefficients" title="the extinction mass coefficients at each of the given wavelengths" min="[0" quantity="masscoefficient"/>
                    <DoubleListProperty name="albedos" title="the scattering albedos at each of the given wavelengths" min="[0" max="1]"/>
                    <DoubleListProperty name="asymmetryParameters" title="the scattering asymmetry parameters at each of the given wavelengths" min="[-1" max="1]"/>
                </properties>
            </Type>
            <Type name="ThemisDustMix" base="MultiGrainDustMix" title="a THEMIS (Jones et al. 2017) dust mix" concrete="true">
                <properties type="Property">
                    <IntProperty name="numSilicateSizes" title="the number of grain size bins for each of the silicate populations" default="5" min="1"/>
                    <IntProperty name="numHydrocarbonSizes" title="the number of grain size bins for each of the hydrocarbon populations" default="5" min="1"/>
                </properties>
            </Type>
            <Type name="DraineLiDustMix" base="MultiGrainDustMix" title="a Draine and Li (2007) dust mix" concrete="true">
                <properties type="Property">
                    <IntProperty name="numSilicateSizes" title="the number of silicate grain size bins" default="5" min="1"/>
                    <IntProperty name="numGraphiteSizes" title="the number of graphite grain size bins (for each of two populations)" default="5" min="1"/>
                    <IntProperty name="numPAHSizes" title="the number of neutral and ionized PAH size bins (each)" default="5" min="1"/>
                </properties>
            </Type>
            <Type name="ZubkoDustMix" base="MultiGrainDustMix" title="a Zubko et al. (2004) dust mix" concrete="true">
                <properties type="Property">
                    <IntProperty name="numSilicateSizes" title="the number of silicate grain size bins" default="5" min="1"/>
                    <IntProperty name="numGraphiteSizes" title="the number of graphite grain size bins" default="5" min="1"/>
                    <IntProperty name="numPAHSizes" title="the number of neutral and ionized PAH size bins (each)" default="5" min="1"/>
                </properties>
            </Type>
            <Type name="WeingartnerDraineDustMix" base="MultiGrainDustMix" title="a Weingartner and Draine (2001) dust mix" concrete="true">
                <properties type="Property">
                    <EnumProperty name="environment" title="the environment determining the dust model" default="MilkyWay">
                        <enumValues type="EnumValue">
                            <EnumValue name="MilkyWay" title="the Milky Way"/>
                            <EnumValue name="LMC" title="the Large Magellanic Cloud"/>
                            <EnumValue name="SMC" title="the Small Magellanic Cloud"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numSilicateSizes" title="the number of silicate grain size bins" default="5" min="1"/>
                    <IntProperty name="numGraphiteSizes" title="the number of graphite grain size bins" default="5" min="1"/>
                    <IntProperty name="numPAHSizes" title="the number of neutral and ionized PAH size bins (each)" default="5" min="1"/>
                </properties>
            </Type>
            <Type name="MRNDustMix" base="MultiGrainDustMix" title="an MRN (1997) dust mix" concrete="true">
                <properties type="Property">
                    <IntProperty name="numSilicateSizes" title="the number of silicate grain size bins" default="5" min="1"/>
                    <IntProperty name="numGraphiteSizes" title="the number of graphite grain size bins" default="5" min="1"/>
                </properties>
            </Type>
            <Type name="TrustBenchmarkDustMix" base="MultiGrainDustMix" title="a TRUST benchmark dust mix" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <IntProperty name="numSilicateSizes" title="the number of silicate grain size bins" default="5" min="1"/>
                    <IntProperty name="numGraphiteSizes" title="the number of graphite grain size bins" default="5" min="1"/>
                    <IntProperty name="numPAHSizes" title="the number of PAH size bins" default="5" min="1"/>
                </properties>
            </Type>
            <Type name="ConfigurableDustMix" base="MultiGrainDustMix" title="a configurable dust mix with one or more grain populations" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <EnumProperty name="scatteringType" title="the type of scattering to be implemented" insert="scatteringTypeSpheroidalPolarization:Spheroidal" default="HenyeyGreenstein">
                        <enumValues type="EnumValue">
                            <EnumValue name="HenyeyGreenstein" title="use the Henyey-Greenstein phase function (unpolarized)"/>
                            <EnumValue name="MaterialPhaseFunction" title="use the phase function derived from actual material properties (unpolarized)"/>
                            <EnumValue name="SphericalPolarization" title="support polarization through scattering by spherical grains"/>
                            <EnumValue name="SpheroidalPolarization" title="support polarization through scattering, absorption and emission by spheroidal grains"/>
                        </enumValues>
                    </EnumProperty>
                    <ItemListProperty name="populations" title="the grain populations" default="GrainPopulation" base="GrainPopulation"/>
                </properties>
            </Type>
            <Type name="FragmentDustMixDecorator" base="MaterialMix" title="a dust mix decorator that manages separate densities for fragments of another dust mix" concrete="true" displayedIf="Level2" insert="CustomMediumState">
                <properties type="Property">
                    <ItemProperty name="dustMix" title="the dust mix to be fragmented" default="ThemisDustMix" base="MultiGrainDustMix"/>
                    <BoolProperty name="fragmentSizeBins" title="fragment each dust population into its grain size bins" default="false"/>
                    <BoolProperty name="hasDynamicDensities" title="allow the fragment densities to be adjusted dynamically" relevantIf="DynamicState" displayedIf="Level3" default="DynamicState:true;false"/>
                    <DoubleProperty name="initialDensityFraction" title="the initial value of the dynamic density fraction" relevantIf="DynamicState&amp;hasDynamicDensities" displayedIf="Level3" default="0" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="ElectronMix" base="MaterialMix" title="a population of electrons" concrete="true">
                <properties type="Property">
                    <BoolProperty name="includePolarization" title="include support for polarization" displayedIf="Level2" default="false"/>
                    <BoolProperty name="includeThermalDispersion" title="include thermal velocity dispersion" relevantIf="Panchromatic" displayedIf="Level2" default="false"/>
                    <DoubleProperty name="defaultTemperature" title="the default temperature of the electron population" relevantIf="Panchromatic&amp;includeThermalDispersion" displayedIf="Level2" default="1e4" min="[3" max="1e8]" quantity="temperature"/>
                </properties>
            </Type>
            <Type name="SpinFlipAbsorptionMix" base="MaterialMix" title="A gas mix supporting the spin-flip 21 cm hydrogen absorption" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="defaultTemperature" title="the default temperature of the gas" displayedIf="Level2" default="1e4" min="[3" max="1e9]" quantity="temperature"/>
                </properties>
            </Type>
            <Type name="SpinFlipHydrogenGasMix" base="EmittingGasMix" title="A gas mix supporting the spin-flip 21 cm hydrogen transition" concrete="true" insert="CustomMediumState,DynamicState">
                <properties type="Property">
                    <DoubleProperty name="defaultMetallicity" title="the default metallicity of the gas" displayedIf="Level2" default="0.02" min="]0" max="0.2]"/>
                    <DoubleProperty name="defaultTemperature" title="the default temperature of the gas" displayedIf="Level2" default="1e4" min="[3" max="1e9]" quantity="temperature"/>
                    <DoubleProperty name="defaultNeutralSurfaceDensity" title="the default neutral hydrogen surface density" displayedIf="Level2" default="10 Msun/pc2" min="]0 Msun/pc2" max="1e9 Msun/pc2]" quantity="masssurfacedensity"/>
                </properties>
            </Type>
            <Type name="XRayAtomicGasMix" base="MaterialMix" title="A gas mix supporting photo-absorption and fluorescence for X-ray wavelengths" concrete="true" insert="GasMix">
                <properties type="Property">
                    <DoubleListProperty name="abundancies" title="the abundancies for the elements with atomic number Z = 1,...,30" displayedIf="Level2" requiredIf="false" min="[0" max="1]"/>
                    <DoubleProperty name="temperature" title="the temperature of the gas or zero to disable thermal dispersion" displayedIf="Level2" default="1e4" min="[0" max="1e9]" quantity="temperature"/>
                    <EnumProperty name="scatterBoundElectrons" title="implementation of scattering by bound electrons" displayedIf="Level3" default="Good">
                        <enumValues type="EnumValue">
                            <EnumValue name="None" title="ignore bound electrons"/>
                            <EnumValue name="Free" title="use free-electron Compton scattering"/>
                            <EnumValue name="FreeWithPolarization" title="use free-electron Compton scattering with support for polarization"/>
                            <EnumValue name="Good" title="use smooth Rayleigh scattering and exact bound-Compton scattering"/>
                            <EnumValue name="Exact" title="use anomalous Rayleigh scattering and exact bound-Compton scattering"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="NonLTELineGasMix" base="EmittingGasMix" title="A gas mix supporting rotational transitions in specific molecules and atoms" concrete="true" insert="CustomMediumState,DynamicState">
                <properties type="Property">
                    <EnumProperty name="species" title="the molecular or atomic species being represented" default="CarbonMonoxide">
                        <enumValues type="EnumValue">
                            <EnumValue name="Test" title="Fictive two-level test molecule (TT)"/>
                            <EnumValue name="Hydroxyl" title="Hydroxyl radical (OH)"/>
                            <EnumValue name="HydroxylHFS" title="Hydroxyl radical (OH) with hyperfine structure"/>
                            <EnumValue name="Formyl" title="Formyl cation (HCO+)"/>
                            <EnumValue name="CarbonMonoxide" title="Carbon monoxide (CO)"/>
                            <EnumValue name="AtomicCarbon" title="Atomic carbon (C)"/>
                            <EnumValue name="IonizedCarbon" title="Ionized carbon (C+)"/>
                            <EnumValue name="MolecularHydrogen" title="Molecular hydrogen (H2)"/>
                        </enumValues>
                    </EnumProperty>
                    <IntProperty name="numEnergyLevels" title="the number of energy levels used (or 999 for all supported)" displayedIf="Level2" default="999" min="2" max="999"/>
                    <DoubleProperty name="defaultTemperature" title="the default temperature of the gas" displayedIf="Level2" default="1000" min="[0" max="1e9]" quantity="temperature"/>
                    <DoubleListProperty name="defaultCollisionPartnerRatios" title="the default relative abundances of the collisional partners" displayedIf="Level2" default="1e4" min="[0" max="1e50]"/>
                    <DoubleProperty name="defaultTurbulenceVelocity" title="the default (non-thermal) turbulence velocity" displayedIf="Level2" default="0 km/s" min="[0 km/s" max="100000 km/s]" quantity="velocity"/>
                    <DoubleProperty name="maxChangeInLevelPopulations" title="the maximum relative change for the level populations in a cell to be considered converged" displayedIf="Level2" default="0.05" min="[0" max="1]"/>
                    <DoubleProperty name="maxFractionNotConvergedCells" title="the maximum fraction of not-converged cells for all cells to be considered converged" displayedIf="Level2" default="0.01" min="[0" max="1]"/>
                    <DoubleProperty name="maxChangeInGlobalLevelPopulations" title="the maximum relative change for the global level populations to be considered converged" displayedIf="Level2" default="0.05" min="[0" max="1]"/>
                    <DoubleProperty name="lowestOpticalDepth" title="Lower limit of (negative) optical depth along a cell diagonal" displayedIf="Level3" default="-2" min="[-10" max="0]"/>
                    <BoolProperty name="storeMeanIntensities" title="store the mean radiation field intensity at each transition line" displayedIf="Level3" default="false"/>
                    <StringProperty name="initialLevelPopsFilename" title="the name of the file with initial level populations" displayedIf="Level3" requiredIf="false"/>
                </properties>
            </Type>
            <Type name="LyaNeutralHydrogenGasMix" base="MaterialMix" title="neutral hydrogen for Lyman-alpha line transfer" concrete="true" displayedIf="Lya" insert="GasMix">
                <properties type="Property">
                    <DoubleProperty name="defaultTemperature" title="the default temperature of the neutral hydrogen gas" displayedIf="Level2" default="1e4" min="[3" max="1e9]" quantity="temperature"/>
                    <BoolProperty name="includePolarization" title="include support for polarization" displayedIf="Level2" default="false"/>
                </properties>
            </Type>
            <Type name="TrivialGasMix" base="MaterialMix" title="A trivial gas mix for testing purposes" concrete="true" displayedIf="Level3" insert="GasMix">
                <properties type="Property">
                    <DoubleProperty name="absorptionCrossSection" title="the absorption cross section per hydrogen atom" quantity="section"/>
                    <DoubleProperty name="scatteringCrossSection" title="the scattering cross section per hydrogen atom" min="[0" quantity="section"/>
                    <DoubleProperty name="asymmetryParameter" title="the scattering asymmetry parameter" min="[-0.95" max="0.95]"/>
                </properties>
            </Type>
            <Type name="SelectDustMixFamily" base="MaterialMixFamily" title="a family of dust mixes specified in the configuration" concrete="true">
                <properties type="Property">
                    <ItemListProperty name="dustMixes" title="the family of dust mixes" default="ConfigurableDustMix" base="DustMix"/>
                </properties>
            </Type>
            <Type name="GrainPopulation" base="SimulationItem" title="a dust grain population" concrete="true">
                <properties type="Property">
                    <ItemProperty name="composition" title="the dust grain composition" default="DraineGraphiteGrainComposition" base="GrainComposition"/>
                    <ItemProperty name="sizeDistribution" title="the dust grain size distribution" default="PowerLawGrainSizeDistribution" base="GrainSizeDistribution"/>
                    <IntProperty name="numSizes" title="the number of grain size bins" default="8" min="1" max="1000"/>
                    <EnumProperty name="normalizationType" title="the mechanism for specifying the amount of dust in the population" default="DustMassPerHydrogenMass">
                        <enumValues type="EnumValue">
                            <EnumValue name="DustMassPerHydrogenAtom" title="an absolute dust mass per hydrogen atom"/>
                            <EnumValue name="DustMassPerHydrogenMass" title="a ratio of dust mass per hydrogen mass"/>
                            <EnumValue name="FactorOnSizeDistribution" title="a proportionality factor on the size distribution"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="dustMassPerHydrogenAtom" title="the dust mass per hydrogen atom" relevantIf="normalizationTypeDustMassPerHydrogenAtom" min="[0" quantity="mass"/>
                    <DoubleProperty name="dustMassPerHydrogenMass" title="the dust mass per hydrogen mass" relevantIf="normalizationTypeDustMassPerHydrogenMass" min="[0" max="1["/>
                    <DoubleProperty name="factorOnSizeDistribution" title="the proportionality factor on the size distribution" relevantIf="normalizationTypeFactorOnSizeDistribution" default="1" min="[0"/>
                </properties>
            </Type>
            <Type name="PowerLawGrainSizeDistribution" base="RangeGrainSizeDistribution" title="a power-law dust grain size distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="exponent" title="the (absolute value of the) exponent in the power-law distribution function" default="3.5" min="]0" max="10]"/>
                </properties>
            </Type>
            <Type name="ModifiedPowerLawGrainSizeDistribution" base="RangeGrainSizeDistribution" title="a modified power-law dust grain size distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="powerLawIndex" title="the index α of the power law" default="-3.5" min="[-10" max="0["/>
                    <DoubleProperty name="turnOffPoint" title="the turn-off point a_t in the exponential decay term" default="0.1 micron" min="[0" max="1 mm]" quantity="grainsize"/>
                    <DoubleProperty name="scaleExponentialDecay" title="the scale a_c in the exponential decay term" default="0.1 micron" min="[1 Angstrom" max="1 mm]" quantity="grainsize"/>
                    <DoubleProperty name="exponentExponentialDecay" title="the exponent γ in the exponential decay term" default="3" min="[0" max="10]"/>
                    <DoubleProperty name="scaleCurvature" title="the scale a_u in the curvature term" default="0.1 micron" min="[1 Angstrom" max="1 mm]" quantity="grainsize"/>
                    <DoubleProperty name="strengthCurvature" title="the strength ζ in the curvature term" default="0.3" min="[-10" max="10]"/>
                    <DoubleProperty name="exponentCurvature" title="the exponent η in the curvature term" default="1" min="[0" max="10]"/>
                </properties>
            </Type>
            <Type name="LogNormalGrainSizeDistribution" base="RangeGrainSizeDistribution" title="a log-normal dust grain size distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="centroid" title="the centroid a0 of the log-normal law" default="1 nm" min="]0" max="1 mm]" quantity="grainsize"/>
                    <DoubleProperty name="width" title="the width σ of the log-normal law" default="0.4" min="]0" max="5]"/>
                </properties>
            </Type>
            <Type name="ModifiedLogNormalGrainSizeDistribution" base="LogNormalGrainSizeDistribution" title="a modified log-normal dust grain size distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="firstMixingParameter" title="the first mixing parameter y0" default="1" min="[0" max="1]"/>
                    <DoubleProperty name="secondMixingParameter" title="the second mixing parameter y1" default="1" min="[0" max="1]"/>
                </properties>
            </Type>
            <Type name="SingleGrainSizeDistribution" base="GrainSizeDistribution" title="a single-size dust grain size distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="size" title="the single grain size for this distribution" min="[1 Angstrom" max="1 mm]" quantity="grainsize"/>
                </properties>
            </Type>
            <Type name="ZubkoSilicateGrainSizeDistribution" base="GrainSizeDistribution" title="a Zubko, Dwek &amp; Arendt size distribution for silicate dust grains" concrete="true"/>
            <Type name="ZubkoGraphiteGrainSizeDistribution" base="GrainSizeDistribution" title="a Zubko, Dwek &amp; Arendt size distribution for graphite dust grains" concrete="true"/>
            <Type name="ZubkoPAHGrainSizeDistribution" base="GrainSizeDistribution" title="a Zubko, Dwek &amp; Arendt size distribution for PAH molecules" concrete="true"/>
            <Type name="HirashitaLogNormalGrainSizeDistribution" base="RangeGrainSizeDistribution" title="a Hirashita (2015) log-normal dust grain size distribution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="centroid" title="the centroid a0 of the log-normal law" default="1 nm" min="]0" max="1 mm]" quantity="grainsize"/>
                    <DoubleProperty name="width" title="the width σ of the log-normal law" default="0.4" min="]0" max="5]"/>
                </properties>
            </Type>
            <Type name="FileGrainSizeDistribution" base="GrainSizeDistribution" title="a dust grain size distribution loaded from a text file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the dust grain size distribution"/>
                </properties>
            </Type>
            <Type name="ListGrainSizeDistribution" base="GrainSizeDistribution" title="a dust grain size distribution specified inside the configuration file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleListProperty name="sizes" title="the grain sizes at which to specify the size distribution" min="[1 Angstrom" max="1 mm]" quantity="grainsize"/>
                    <DoubleListProperty name="sizeDistributionValues" title="the size distribution values at each of the given grain sizes" min="]0" quantity="pergrainsize"/>
                </properties>
            </Type>
            <Type name="DraineSilicateGrainComposition" base="GrainComposition" title="a Draine silicate dust grain composition" concrete="true"/>
            <Type name="DraineGraphiteGrainComposition" base="GrainComposition" title="a Draine graphite dust grain composition" concrete="true"/>
            <Type name="DraineNeutralPAHGrainComposition" base="GrainComposition" title="a Draine neutral PAH dust grain composition" concrete="true"/>
            <Type name="DraineIonizedPAHGrainComposition" base="GrainComposition" title="a Draine ionized PAH dust grain composition" concrete="true"/>
            <Type name="MieSilicateGrainComposition" base="GrainComposition" title="a MieX-based Draine silicate dust grain composition" concrete="true"/>
            <Type name="MinSilicateGrainComposition" base="GrainComposition" title="a Min 2007 amorphous silicate dust grain composition" concrete="true"/>
            <Type name="PolarizedSilicateGrainComposition" base="GrainComposition" title="a silicate dust grain composition with support for polarization" concrete="true"/>
            <Type name="PolarizedGraphiteGrainComposition" base="GrainComposition" title="a graphite dust grain composition with support for polarization" concrete="true"/>
            <Type name="CrystalEnstatiteGrainComposition" base="GrainComposition" title="a crystalline Enstatite dust grain composition" concrete="true"/>
            <Type name="CrystalForsteriteGrainComposition" base="GrainComposition" title="a crystalline Forsterite dust grain composition" concrete="true"/>
            <Type name="DustEmGrainComposition" base="GrainComposition" title="a dust grain composition based on DustEM data" concrete="true">
                <properties type="Property">
                    <EnumProperty name="grainType" title="the DustEM grain type">
                        <enumValues type="EnumValue">
                            <EnumValue name="aSil" title="astronomical silicate grains (Draine &amp; Li 2007)"/>
                            <EnumValue name="Gra" title="graphite grains (Draine &amp; Li 2001; Li &amp; Draine 2001)"/>
                            <EnumValue name="PAH0DL07" title="neutral PAHs (Draine &amp; Li 2007)"/>
                            <EnumValue name="PAH1DL07" title="ionized PAHs (Draine &amp; Li 2007)"/>
                            <EnumValue name="PAH0MC10" title="neutral PAHs (Compiègne et al. 2011)"/>
                            <EnumValue name="PAH1MC10" title="ionized PAHs (Compiègne et al. 2011)"/>
                            <EnumValue name="CM20" title="amorphous hydro-carbon grains (Jones et al. 2013)"/>
                            <EnumValue name="aOlM5" title="amorphous olivine/forsterite grains (Koehler et al. 2014)"/>
                            <EnumValue name="aPyM5" title="amorphous pyroxene/enstatite grains (Koehler et al. 2014)"/>
                        </enumValues>
                    </EnumProperty>
                    <DoubleProperty name="bulkMassDensity" title="the bulk mass density for this grain material" default="grainTypeaSil:3500 kg/m3;grainTypeCM20:1600 kg/m3;grainTypeaOlM5|grainTypeaPyM5:2190 kg/m3;2240 kg/m3" min="[100 kg/m3" max="10000 kg/m3]" quantity="bulkmassdensity"/>
                </properties>
            </Type>
            <Type name="BegemannPorousAluminaGrainComposition" base="GrainComposition" title="a Begemann porous alumina dust grain composition" concrete="true"/>
            <Type name="HofmeisterPericlaseGrainComposition" base="GrainComposition" title="a Hofmeister periclase dust grain composition" concrete="true"/>
            <Type name="DorschnerOlivineGrainComposition" base="GrainComposition" title="a Dorschner olivine dust grain composition" concrete="true"/>
            <Type name="TrustSilicateGrainComposition" base="GrainComposition" title="a TRUST benchmark silicate dust grain composition" concrete="true"/>
            <Type name="TrustGraphiteGrainComposition" base="GrainComposition" title="a TRUST benchmark graphite dust grain composition" concrete="true"/>
            <Type name="TrustNeutralPAHGrainComposition" base="GrainComposition" title="a TRUST benchmark neutral PAH dust grain composition" concrete="true"/>
            <Type name="SpheroidalSilicateGrainComposition" base="PolarizedSilicateGrainComposition" title="a spheroidal silicate dust grain composition with support for polarization" concrete="true" displayedIf="Spheroidal">
                <properties type="Property">
                    <EnumProperty name="tableType" title="the type of emission tables to use" default="Builtin">
                        <enumValues type="EnumValue">
                            <EnumValue name="Builtin" title="builtin resources"/>
                            <EnumValue name="OneTable" title="single custom table"/>
                            <EnumValue name="TwoTables" title="two custom tables with interpolation"/>
                        </enumValues>
                    </EnumProperty>
                    <StringProperty name="emissionTable" title="the name of the file tabulating properties for polarized emission by arbitrarily aligned spheroidal grains" relevantIf="tableTypeOneTable"/>
                    <StringProperty name="alignedEmissionTable" title="the name of the file tabulating properties for polarized emission by perfectly aligned spheroidal grains" relevantIf="tableTypeTwoTables"/>
                    <StringProperty name="nonAlignedEmissionTable" title="the name of the file tabulating properties for polarized emission by non-aligned spheroidal grains" relevantIf="tableTypeTwoTables"/>
                    <DoubleProperty name="alignmentFraction" title="the alignment fraction of the spheroidal grains with the local magnetic field" relevantIf="tableTypeBuiltin|tableTypeTwoTables" default="1." min="0." max="1."/>
                </properties>
            </Type>
            <Type name="SpheroidalGraphiteGrainComposition" base="PolarizedGraphiteGrainComposition" title="a spheroidal graphite dust grain composition with support for polarization" concrete="true" displayedIf="Spheroidal">
                <properties type="Property">
                    <EnumProperty name="tableType" title="the type of emission tables to use" default="Builtin">
                        <enumValues type="EnumValue">
                            <EnumValue name="Builtin" title="builtin resources"/>
                            <EnumValue name="OneTable" title="single custom table"/>
                            <EnumValue name="TwoTables" title="two custom tables with interpolation"/>
                        </enumValues>
                    </EnumProperty>
                    <StringProperty name="emissionTable" title="the name of the file tabulating properties for polarized emission by arbitrarily aligned spheroidal grains" relevantIf="tableTypeOneTable"/>
                    <StringProperty name="alignedEmissionTable" title="the name of the file tabulating properties for polarized emission by perfectly aligned spheroidal grains" relevantIf="tableTypeTwoTables"/>
                    <StringProperty name="nonAlignedEmissionTable" title="the name of the file tabulating properties for polarized emission by non-aligned spheroidal grains" relevantIf="tableTypeTwoTables"/>
                    <DoubleProperty name="alignmentFraction" title="the alignment fraction of the spheroidal grains with the local magnetic field" relevantIf="tableTypeTwoTables" default="1." min="0." max="1."/>
                </properties>
            </Type>
            <Type name="AllCellsLibrary" base="SpatialCellLibrary" title="a library scheme that has a separate entry for every spatial cell" concrete="true"/>
            <Type name="FieldStrengthCellLibrary" base="SpatialCellLibrary" title="a library scheme for grouping spatial cells based on radiation field strength" concrete="true" insert="NonIdentitySpatialCellLibrary">
                <properties type="Property">
                    <IntProperty name="numFieldStrengths" title="the number of field strength bins" default="1000" min="10" max="10000000"/>
                </properties>
            </Type>
            <Type name="TemperatureWavelengthCellLibrary" base="SpatialCellLibrary" title="a library scheme for grouping spatial cells based on indicative temperature and wavelength" concrete="true" insert="NonIdentitySpatialCellLibrary">
                <properties type="Property">
                    <IntProperty name="numTemperatures" title="the number of temperature bins" default="40" min="5" max="10000"/>
                    <IntProperty name="numWavelengths" title="the number of wavelength bins" default="25" min="5" max="10000"/>
                </properties>
            </Type>
            <Type name="ClearDensityRecipe" base="DynamicStateRecipe" title="a recipe that clears material in cells above a given radiation field strength" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="fieldStrengthThreshold" title="the field strength above which material is cleared from a cell" default="1" min="[0"/>
                </properties>
            </Type>
            <Type name="LinearDustDestructionRecipe" base="DustDestructionRecipe" title="a dust destruction recipe using a linear temperature dependence" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minSilicateTemperature" title="the temperature below which silicate grains are not destroyed" default="1200 K" min="[3 K" max="30000 K]" quantity="temperature"/>
                    <DoubleProperty name="maxSilicateTemperature" title="the temperature above which all silicate grains are destroyed" default="1200 K" min="[3 K" max="30000 K]" quantity="temperature"/>
                    <DoubleProperty name="minGraphiteTemperature" title="the temperature below which graphite grains are not destroyed" default="2000 K" min="[3 K" max="30000 K]" quantity="temperature"/>
                    <DoubleProperty name="maxGraphiteTemperature" title="the temperature above which all graphite grains are destroyed" default="2000 K" min="[3 K" max="30000 K]" quantity="temperature"/>
                </properties>
            </Type>
            <Type name="LogWavelengthGrid" base="DisjointWavelengthGrid" title="a logarithmic wavelength grid" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <IntProperty name="numWavelengths" title="the number of wavelength grid points" default="25" min="2"/>
                </properties>
            </Type>
            <Type name="NestedLogWavelengthGrid" base="DisjointWavelengthGrid" title="a nested logarithmic wavelength grid" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelengthBaseGrid" title="the shortest wavelength of the low-resolution grid" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelengthBaseGrid" title="the longest wavelength of the low-resolution grid" min="1 pm" max="1 m" quantity="wavelength"/>
                    <IntProperty name="numWavelengthsBaseGrid" title="the number of wavelength grid points in the low-resolution grid" default="25" min="2"/>
                    <DoubleProperty name="minWavelengthSubGrid" title="the shortest wavelength of the high-resolution subgrid" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelengthSubGrid" title="the longest wavelength of the high-resolution subgrid" min="1 pm" max="1 m" quantity="wavelength"/>
                    <IntProperty name="numWavelengthsSubGrid" title="the number of wavelength grid points in the high-resolution subgrid" default="25" min="2"/>
                </properties>
            </Type>
            <Type name="LinWavelengthGrid" base="DisjointWavelengthGrid" title="a linear wavelength grid" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <IntProperty name="numWavelengths" title="the number of wavelength grid points" default="25" min="2"/>
                </properties>
            </Type>
            <Type name="ResolutionWavelengthGrid" base="DisjointWavelengthGrid" title="a logarithmic wavelength grid with given spectral resolution" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="resolution" title="the spectral resolution R of the grid" default="10" min="[1e-6" max="1e6]"/>
                </properties>
            </Type>
            <Type name="FileWavelengthGrid" base="DisjointWavelengthGrid" title="a wavelength grid loaded from a text file" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the characteristic wavelengths"/>
                    <DoubleProperty name="relativeHalfWidth" title="the relative half width for discrete bins, or zero for a consecutive range" default="0" min="[0" max="1["/>
                    <BoolProperty name="log" title="use logarithmic scale" relevantIf="!relativeHalfWidth" default="true"/>
                </properties>
            </Type>
            <Type name="ListWavelengthGrid" base="DisjointWavelengthGrid" title="a wavelength grid configured as a list" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the characteristic wavelength for each bin" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="relativeHalfWidth" title="the relative half width for discrete bins, or zero for a consecutive range" default="0" min="[0" max="1["/>
                    <BoolProperty name="log" title="use logarithmic scale" relevantIf="!relativeHalfWidth" default="true"/>
                </properties>
            </Type>
            <Type name="LogBorderWavelengthGrid" base="DisjointWavelengthGrid" title="a logarithmic wavelength grid with given outer borders" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <IntProperty name="numWavelengthBins" title="the number of wavelength bins" default="25" min="1"/>
                </properties>
            </Type>
            <Type name="LinBorderWavelengthGrid" base="DisjointWavelengthGrid" title="a linear wavelength grid with given outer borders" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <IntProperty name="numWavelengthBins" title="the number of wavelength bins" default="25" min="1"/>
                </properties>
            </Type>
            <Type name="ResolutionBorderWavelengthGrid" base="DisjointWavelengthGrid" title="a logarithmic wavelength grid with given spectral resolution and outer borders" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="minWavelength" title="the shortest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="maxWavelength" title="the longest wavelength" min="1 pm" max="1 m" quantity="wavelength"/>
                    <DoubleProperty name="resolution" title="the spectral resolution R of the grid" default="10" min="[1e-6" max="1e6]"/>
                </properties>
            </Type>
            <Type name="FileBorderWavelengthGrid" base="DisjointWavelengthGrid" title="a wavelength grid loaded from a text file listing bin borders" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file with the wavelength bin borders"/>
                    <EnumProperty name="characteristic" title="determine the characteristic wavelength for each bin" default="Logarithmic">
                        <enumValues type="EnumValue">
                            <EnumValue name="Linear" title="using linear interpolation"/>
                            <EnumValue name="Logarithmic" title="using logarithmic interpolation"/>
                            <EnumValue name="Specified" title="specified in the imported wavelength list"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="ListBorderWavelengthGrid" base="DisjointWavelengthGrid" title="a wavelength grid configured as a list of bin borders" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleListProperty name="wavelengths" title="the wavelength bin borders" min="0 pm" max="1 m" quantity="wavelength"/>
                    <EnumProperty name="characteristic" title="determine the characteristic wavelength for each bin" default="Logarithmic">
                        <enumValues type="EnumValue">
                            <EnumValue name="Linear" title="using linear interpolation"/>
                            <EnumValue name="Logarithmic" title="using logarithmic interpolation"/>
                            <EnumValue name="Specified" title="specified in the configured wavelength list"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="CompositeWavelengthGrid" base="DisjointWavelengthGrid" title="a wavelength grid composited from a list of wavelength grids" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <ItemListProperty name="wavelengthGrids" title="the wavelength grids to be composited" default="LogWavelengthGrid" base="DisjointWavelengthGrid"/>
                    <BoolProperty name="log" title="use logarithmic scale" default="true"/>
                </properties>
            </Type>
            <Type name="PredefinedBandWavelengthGrid" base="BandWavelengthGrid" title="a wavelength grid including a predefined list of (broad)bands" concrete="true">
                <properties type="Property">
                    <BoolProperty name="includeGALEX" title="include GALEX FUV and NUV bands" default="true"/>
                    <BoolProperty name="includeSDSS" title="include SDSS ugriz bands" default="true"/>
                    <BoolProperty name="include2MASS" title="include 2MASS J, H and Ks bands" default="true"/>
                    <BoolProperty name="includeWISE" title="include WISE W1, W2, W3 and W4 bands" default="DustEmission:true;false"/>
                    <BoolProperty name="includeHERSCHEL" title="include HERSCHEL PACS 70,100,160 and SPIRE 250,350,500 bands" default="DustEmission:true;false"/>
                </properties>
            </Type>
            <Type name="ConfigurableBandWavelengthGrid" base="BandWavelengthGrid" title="a wavelength grid including a configurable list of (broad)bands" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <ItemListProperty name="bands" title="the (broad)bands defining this wavelength grid" default="BroadBand" base="Band"/>
                </properties>
            </Type>
            <Type name="InstrumentSystem" base="SimulationItem" title="an instrument system" concrete="true">
                <properties type="Property">
                    <ItemProperty name="defaultWavelengthGrid" title="the default instrument wavelength grid" relevantIf="Panchromatic" requiredIf="!Level2" insert="defaultWavelengthGrid:DefaultInstrumentWavelengthGrid" default="LogWavelengthGrid" base="WavelengthGrid"/>
                    <ItemListProperty name="instruments" title="the instruments" requiredIf="false" default="SEDInstrument" base="Instrument"/>
                </properties>
            </Type>
            <Type name="SEDInstrument" base="DistantInstrument" title="a distant instrument that outputs the spatially integrated flux density as an SED" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="radius" title="the radius of the circular aperture, or zero for no aperture" displayedIf="Level2" default="0" min="[0" quantity="length"/>
                </properties>
            </Type>
            <Type name="FrameInstrument" base="DistantInstrument" title="a distant instrument that outputs the surface brightness in every pixel as a data cube" concrete="true">
                <properties type="Property">
                    <DoubleProperty name="fieldOfViewX" title="the total field of view in the horizontal direction" min="]0" quantity="length"/>
                    <IntProperty name="numPixelsX" title="the number of pixels in the horizontal direction" default="250" min="1" max="10000"/>
                    <DoubleProperty name="centerX" title="the center of the frame in the horizontal direction" displayedIf="Level2" default="0" quantity="length"/>
                    <DoubleProperty name="fieldOfViewY" title="the total field of view in the vertical direction" min="]0" quantity="length"/>
                    <IntProperty name="numPixelsY" title="the number of pixels in the vertical direction" default="250" min="1" max="10000"/>
                    <DoubleProperty name="centerY" title="the center of the frame in the vertical direction" displayedIf="Level2" default="0" quantity="length"/>
                </properties>
            </Type>
            <Type name="FullInstrument" base="FrameInstrument" title="a distant instrument that outputs both the flux density (SED) and surface brightness (data cube)" concrete="true"/>
            <Type name="AllSkyInstrument" base="Instrument" title="an all-sky instrument (for observing inside a model)" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="projection" title="the projection used for mapping the sky to a rectangle" default="HammerAitoffProjection" base="AllSkyProjection"/>
                    <IntProperty name="numPixelsY" title="the number of image pixels in the vertical (shortest) direction" default="250" min="25" max="10000"/>
                    <DoubleProperty name="radius" title="the radius of the observer&apos;s all-sky sphere" min="]0" quantity="length"/>
                    <DoubleProperty name="observerX" title="the position of the observer, x component" quantity="length"/>
                    <DoubleProperty name="observerY" title="the position of the observer, y component" quantity="length"/>
                    <DoubleProperty name="observerZ" title="the position of the observer, z component" quantity="length"/>
                    <DoubleProperty name="crossX" title="the position of the crosshair, x component" default="0" quantity="length"/>
                    <DoubleProperty name="crossY" title="the position of the crosshair, y component" default="0" quantity="length"/>
                    <DoubleProperty name="crossZ" title="the position of the crosshair, z component" default="0" quantity="length"/>
                    <DoubleProperty name="upX" title="the upwards direction, x component" default="0" quantity="length"/>
                    <DoubleProperty name="upY" title="the upwards direction, y component" default="0" quantity="length"/>
                    <DoubleProperty name="upZ" title="the upwards direction, z component" default="1" quantity="length"/>
                </properties>
            </Type>
            <Type name="HEALPixSkyInstrument" base="Instrument" title="a HEALPix all-sky instrument (for Planck-like observations inside a model)" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <IntProperty name="order" title="HEALPix order" default="6" min="0" max="15"/>
                    <DoubleProperty name="radius" title="the radius of the observer&apos;s all-sky sphere" min="]0" quantity="length"/>
                    <DoubleProperty name="observerX" title="the position of the observer, x component" quantity="length"/>
                    <DoubleProperty name="observerY" title="the position of the observer, y component" quantity="length"/>
                    <DoubleProperty name="observerZ" title="the position of the observer, z component" quantity="length"/>
                    <DoubleProperty name="crossX" title="the position of the crosshair, x component" default="0" quantity="length"/>
                    <DoubleProperty name="crossY" title="the position of the crosshair, y component" default="0" quantity="length"/>
                    <DoubleProperty name="crossZ" title="the position of the crosshair, z component" default="0" quantity="length"/>
                    <DoubleProperty name="upX" title="the upwards direction, x component" default="0" quantity="length"/>
                    <DoubleProperty name="upY" title="the upwards direction, y component" default="0" quantity="length"/>
                    <DoubleProperty name="upZ" title="the upwards direction, z component" default="1" quantity="length"/>
                </properties>
            </Type>
            <Type name="PerspectiveInstrument" base="Instrument" title="a perspective instrument (mostly for making movies)" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <IntProperty name="numPixelsX" title="the number of viewport pixels in the horizontal direction" default="250" min="25" max="10000"/>
                    <IntProperty name="numPixelsY" title="the number of viewport pixels in the vertical direction" default="250" min="25" max="10000"/>
                    <DoubleProperty name="width" title="the width of the viewport" min="]0" quantity="length"/>
                    <DoubleProperty name="viewX" title="the position of the viewport origin, x component" quantity="length"/>
                    <DoubleProperty name="viewY" title="the position of the viewport origin, y component" quantity="length"/>
                    <DoubleProperty name="viewZ" title="the position of the viewport origin, z component" quantity="length"/>
                    <DoubleProperty name="crossX" title="the position of the crosshair, x component" quantity="length"/>
                    <DoubleProperty name="crossY" title="the position of the crosshair, y component" quantity="length"/>
                    <DoubleProperty name="crossZ" title="the position of the crosshair, z component" quantity="length"/>
                    <DoubleProperty name="upX" title="the upwards direction, x component" quantity="length"/>
                    <DoubleProperty name="upY" title="the upwards direction, y component" quantity="length"/>
                    <DoubleProperty name="upZ" title="the upwards direction, z component" quantity="length"/>
                    <DoubleProperty name="focal" title="the distance from the eye to the viewport origin" min="]0" quantity="length"/>
                </properties>
            </Type>
            <Type name="HammerAitoffProjection" base="AllSkyProjection" title="the Hammer-Aitoff all-sky projection" concrete="true"/>
            <Type name="MollweideProjection" base="AllSkyProjection" title="the Mollweide all-sky projection" concrete="true"/>
            <Type name="ProbeSystem" base="SimulationItem" title="a probe system" concrete="true">
                <properties type="Property">
                    <ItemListProperty name="probes" title="the probes" requiredIf="false" default="!NoMedium:ConvergenceInfoProbe;LuminosityProbe" base="Probe"/>
                </properties>
            </Type>
            <Type name="ConvergenceInfoProbe" base="SpecialtyWavelengthProbe" title="convergence: information on the spatial grid" concrete="true" displayedIf="Medium&amp;SpatialGrid"/>
            <Type name="ConvergenceCutsProbe" base="SpecialtyWhenProbe" title="convergence: cuts of the medium density along the coordinate planes" concrete="true" displayedIf="Medium&amp;SpatialGrid"/>
            <Type name="LuminosityProbe" base="SpecialtyWavelengthGridProbe" title="source: luminosities of primary sources" concrete="true" displayedIf="Source"/>
            <Type name="LaunchedPacketsProbe" base="SpecialtyWavelengthGridProbe" title="source: number of photon packets launched from primary and secondary sources" concrete="true" displayedIf="Level2&amp;Source"/>
            <Type name="DensityProbe" base="SpatialGridWhenFormProbe" title="internal spatial grid: density of the medium" concrete="true" displayedIf="Medium&amp;SpatialGrid">
                <properties type="Property">
                    <EnumProperty name="aggregation" title="how to aggregate the density" displayedIf="Level2" default="Type">
                        <enumValues type="EnumValue">
                            <EnumValue name="Fragment" title="per fragment (dust grain material type and/or size bin)"/>
                            <EnumValue name="Component" title="per medium component"/>
                            <EnumValue name="Type" title="per medium type (dust, electrons, gas)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="OpacityProbe" base="SpatialGridWhenFormProbe" title="internal spatial grid: opacity of the medium" concrete="true" displayedIf="Medium&amp;SpatialGrid">
                <properties type="Property">
                    <DoubleProperty name="wavelength" title="the wavelength at which to determine the opacity" displayedIf="Level2" default="0.55 micron" min="1 pm" max="1 m" quantity="wavelength"/>
                    <EnumProperty name="aggregation" title="how to aggregate the opacity" displayedIf="Level2" default="Type">
                        <enumValues type="EnumValue">
                            <EnumValue name="Fragment" title="per fragment (dust grain material type and/or size bin)"/>
                            <EnumValue name="Component" title="per medium component"/>
                            <EnumValue name="Type" title="per medium type (dust, electrons, gas)"/>
                            <EnumValue name="System" title="for the complete medium system"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="TemperatureProbe" base="SpatialGridWhenFormProbe" title="internal spatial grid: indicative temperature of the medium" concrete="true" displayedIf="Medium&amp;SpatialGrid&amp;((DustMix&amp;RadiationField&amp;Panchromatic)|ElectronMix|GasMix)">
                <properties type="Property">
                    <EnumProperty name="aggregation" title="how to aggregate the indicative temperature" displayedIf="Level2" insert="thisIsTemperatureProbe" default="Type">
                        <enumValues type="EnumValue">
                            <EnumValue name="Fragment" title="per fragment (dust grain material type and/or size bin)"/>
                            <EnumValue name="Component" title="per medium component"/>
                            <EnumValue name="Type" title="per medium type (dust, electrons, gas)"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="MetallicityProbe" base="SpatialGridWhenFormProbe" title="internal spatial grid: metallicity of the gas medium" concrete="true" displayedIf="Medium&amp;SpatialGrid&amp;GasMix"/>
            <Type name="VelocityProbe" base="SpatialGridFormProbe" title="internal spatial grid: bulk velocity of the medium" concrete="true" displayedIf="Level2&amp;SpatialGrid&amp;MediumVelocity"/>
            <Type name="MagneticFieldProbe" base="SpatialGridFormProbe" title="internal spatial grid: magnetic field associated with the medium" concrete="true" displayedIf="Level3&amp;SpatialGrid&amp;MagneticField"/>
            <Type name="CustomStateProbe" base="SpatialGridWhenFormProbe" title="internal spatial grid: custom medium state quantities" concrete="true" displayedIf="Level3&amp;CustomMediumState">
                <properties type="Property">
                    <StringProperty name="indices" title="zero-based indices or index ranges of quantities to probe, or empty for all" requiredIf="false"/>
                </properties>
            </Type>
            <Type name="RadiationFieldProbe" base="SpatialGridFormProbe" title="internal spatial grid: the mean radiation field intensity" concrete="true" displayedIf="Level2&amp;SpatialGrid&amp;RadiationField">
                <properties type="Property">
                    <BoolProperty name="writeWavelengthGrid" title="output a text file with the radiation field wavelength grid" default="false"/>
                    <EnumProperty name="probeAfter" title="perform the probe after" displayedIf="DynamicState|IterateSecondary" default="Run">
                        <enumValues type="EnumValue">
                            <EnumValue name="Run" title="after the complete simulation run"/>
                            <EnumValue name="Primary" title="after each iteration over primary emission"/>
                            <EnumValue name="Secondary" title="after each iteration over secondary emission"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SecondaryDustLuminosityProbe" base="SpatialGridFormProbe" title="internal spatial grid: secondary dust luminosity" concrete="true" displayedIf="DustMix&amp;DustEmission">
                <properties type="Property">
                    <EnumProperty name="probeAfter" title="perform the probe after" displayedIf="IterateSecondary" default="Run">
                        <enumValues type="EnumValue">
                            <EnumValue name="Run" title="after the complete simulation run"/>
                            <EnumValue name="Secondary" title="after each iteration over secondary emission"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SecondaryLineLuminosityProbe" base="SpatialGridFormProbe" title="internal spatial grid: secondary line luminosity" concrete="true" displayedIf="Level2&amp;SpatialGrid&amp;GasEmission">
                <properties type="Property">
                    <EnumProperty name="probeAfter" title="perform the probe after" displayedIf="IterateSecondary" default="Run">
                        <enumValues type="EnumValue">
                            <EnumValue name="Run" title="after the complete simulation run"/>
                            <EnumValue name="Secondary" title="after each iteration over secondary emission"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="SpatialCellPropertiesProbe" base="SpecialtyWavelengthProbe" title="properties: basic info for each spatial cell" concrete="true" displayedIf="Medium&amp;SpatialGrid"/>
            <Type name="SpatialGridPlotProbe" base="SpecialtyProbe" title="properties: data files for plotting the structure of the grid" concrete="true" displayedIf="SpatialGrid"/>
            <Type name="OpticalMaterialPropertiesProbe" base="SpecialtyWavelengthGridProbe" title="properties: aggregate optical material properties for each medium" concrete="true" displayedIf="Medium"/>
            <Type name="DustGrainPopulationsProbe" base="SpecialtyProbe" title="properties: dust grain population mass and size information" concrete="true" displayedIf="Level2&amp;Medium&amp;MultiGrainDustMix"/>
            <Type name="DustGrainSizeDistributionProbe" base="SpecialtyProbe" title="properties: dust grain size distribution" concrete="true" displayedIf="Level2&amp;Medium&amp;MultiGrainDustMix">
                <properties type="Property">
                    <IntProperty name="numSamples" title="the number of samples in the size distribution table" default="250" min="3" max="100000"/>
                </properties>
            </Type>
            <Type name="DustEmissivityProbe" base="SpecialtyProbe" title="properties: emissivity spectrum for each dust mix in a range of standard fields" concrete="true" displayedIf="Level3&amp;DustMix&amp;DustEmission">
                <properties type="Property">
                    <BoolProperty name="writeWavelengthGrid" title="output a text file with the emission spectrum wavelength grid" default="false"/>
                </properties>
            </Type>
            <Type name="RadiationFieldWavelengthGridProbe" base="SpecialtyProbe" title="wavelength grid: radiation field " concrete="true" displayedIf="Level2&amp;Medium&amp;SpatialGrid&amp;RadiationField"/>
            <Type name="DustEmissionWavelengthGridProbe" base="SpecialtyProbe" title="wavelength grid: dust emission" concrete="true" displayedIf="Level2&amp;DustMix&amp;DustEmission"/>
            <Type name="InstrumentWavelengthGridProbe" base="SpecialtyProbe" title="wavelength grid: instruments" concrete="true" displayedIf="Level2&amp;Instrument"/>
            <Type name="DustAbsorptionPerCellProbe" base="SpecialtyProbe" title="specialty: spectral luminosity absorbed by dust for each spatial cell" concrete="true" displayedIf="Level3&amp;DustMix&amp;SpatialGrid&amp;RadiationField">
                <properties type="Property">
                    <BoolProperty name="writeWavelengthGrid" title="output a text file with the radiation field wavelength grid" default="false"/>
                </properties>
            </Type>
            <Type name="SpatialGridSourceDensityProbe" base="SpecialtyProbe" title="specialty: primary source density discretized on spatial grid" concrete="true" displayedIf="Level3&amp;GeometricSource&amp;SpatialGrid"/>
            <Type name="TreeSpatialGridTopologyProbe" base="SpecialtyProbe" title="specialty: data file representing the topology of the tree spatial grid" concrete="true" displayedIf="Level3&amp;TreeSpatialGrid"/>
            <Type name="ImportedSourceLuminosityProbe" base="InputModelFormProbe" title="imported source: specific luminosity density" concrete="true" displayedIf="ImportedSource">
                <properties type="Property">
                    <ItemProperty name="wavelengthGrid" title="the wavelength grid for this probe" relevantIf="Panchromatic" displayedIf="Level2" requiredIf="!DefaultInstrumentWavelengthGrid" base="WavelengthGrid"/>
                    <BoolProperty name="convolve" title="average or convolve the specific luminosity over the wavelength bin" relevantIf="Panchromatic" default="false"/>
                </properties>
            </Type>
            <Type name="ImportedSourceDensityProbe" base="InputModelFormProbe" title="imported source: mass density" concrete="true" displayedIf="ImportedSource">
                <properties type="Property">
                    <EnumProperty name="massType" title="type of mass being probed" displayedIf="CurrentMass" default="InitialMass">
                        <enumValues type="EnumValue">
                            <EnumValue name="InitialMass" title="initial mass"/>
                            <EnumValue name="CurrentMass" title="current mass"/>
                        </enumValues>
                    </EnumProperty>
                </properties>
            </Type>
            <Type name="ImportedSourceMetallicityProbe" base="ImportedSourceWeightedProbe" title="imported source: metallicity" concrete="true"/>
            <Type name="ImportedSourceAgeProbe" base="ImportedSourceWeightedProbe" title="imported source: age" concrete="true"/>
            <Type name="ImportedSourceVelocityProbe" base="ImportedSourceWeightedProbe" title="imported source: bulk velocity" concrete="true" displayedIf="ImportedSource&amp;SourceVelocity"/>
            <Type name="ImportedMediumDensityProbe" base="InputModelFormProbe" title="imported medium: mass or number density" concrete="true" displayedIf="ImportedMedium"/>
            <Type name="ImportedMediumMetallicityProbe" base="InputModelFormProbe" title="imported medium: metallicity" concrete="true" displayedIf="ImportedMedium"/>
            <Type name="ImportedMediumTemperatureProbe" base="InputModelFormProbe" title="imported medium: temperature" concrete="true" displayedIf="ImportedMedium"/>
            <Type name="ImportedMediumVelocityProbe" base="InputModelFormProbe" title="imported medium: bulk velocity" concrete="true" displayedIf="ImportedMedium&amp;MediumVelocity"/>
            <Type name="DefaultCutsForm" base="SpatialGridForm" title="default planar cuts along the coordinate planes" concrete="true"/>
            <Type name="PlanarCutsForm" base="GenericForm" title="configurable planar cuts parallel to the coordinate planes" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="minX" title="the start point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="maxX" title="the end point of the box in the X direction" quantity="length"/>
                    <DoubleProperty name="minY" title="the start point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="maxY" title="the end point of the box in the Y direction" quantity="length"/>
                    <DoubleProperty name="minZ" title="the start point of the box in the Z direction" quantity="length"/>
                    <DoubleProperty name="maxZ" title="the end point of the box in the Z direction" quantity="length"/>
                    <DoubleProperty name="positionX" title="the x position of the cut parallel to the yz plane" default="0" quantity="length"/>
                    <DoubleProperty name="positionY" title="the y position of the cut parallel to the xz plane" default="0" quantity="length"/>
                    <DoubleProperty name="positionZ" title="the z position of the cut parallel to the xy plane" default="0" quantity="length"/>
                    <IntProperty name="numPixelsX" title="the number of pixels in the x direction" default="1024" min="1" max="10000"/>
                    <IntProperty name="numPixelsY" title="the number of pixels in the y direction" default="1024" min="1" max="10000"/>
                    <IntProperty name="numPixelsZ" title="the number of pixels in the z direction" default="1024" min="1" max="10000"/>
                </properties>
            </Type>
            <Type name="PerCellForm" base="SpatialGridForm" title="a text column file with values for each spatial cell" concrete="true"/>
            <Type name="LinearCutForm" base="GenericForm" title="a text column file with values along a given line segment" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <IntProperty name="numSamples" title="the number of samples along the line segment" default="250" min="3" max="100000"/>
                    <DoubleProperty name="startX" title="the position of the starting point, x component" quantity="length"/>
                    <DoubleProperty name="startY" title="the position of the starting point, y component" quantity="length"/>
                    <DoubleProperty name="startZ" title="the position of the starting point, z component" quantity="length"/>
                    <DoubleProperty name="endX" title="the position of the ending point, x component" quantity="length"/>
                    <DoubleProperty name="endY" title="the position of the ending point, y component" quantity="length"/>
                    <DoubleProperty name="endZ" title="the position of the ending point, z component" quantity="length"/>
                </properties>
            </Type>
            <Type name="MeridionalCutForm" base="GenericForm" title="a text column file with values along a meridian" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <IntProperty name="numSamples" title="the number of samples along the meridian" default="250" min="3" max="100000"/>
                    <DoubleProperty name="radius" title="the radius of the circle containing the meridian" min="]0" quantity="length"/>
                    <DoubleProperty name="azimuth" title="the azimuth angle φ of the meridian" displayedIf="Dimension3" default="0 deg" min="-360 deg" max="360 deg" quantity="posangle"/>
                </properties>
            </Type>
            <Type name="AtPositionsForm" base="GenericForm" title="a text column file with values for each imported position" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <StringProperty name="filename" title="the name of the file listing the positions"/>
                    <StringProperty name="useColumns" title="a list of names corresponding to columns in the file to be imported" displayedIf="Level3" requiredIf="false"/>
                </properties>
            </Type>
            <Type name="ParallelProjectionForm" base="GenericForm" title="parallel projection on a distant plane" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <DoubleProperty name="inclination" title="the inclination angle θ of the projection" displayedIf="Dimension2|Dimension3" default="0 deg" min="0 deg" max="180 deg" quantity="posangle"/>
                    <DoubleProperty name="azimuth" title="the azimuth angle φ of the projection" displayedIf="Dimension3" default="0 deg" min="-360 deg" max="360 deg" quantity="posangle"/>
                    <DoubleProperty name="roll" title="the roll angle ω of the projection" displayedIf="Level2&amp;(Dimension2|Dimension3)" default="0 deg" min="-360 deg" max="360 deg" quantity="posangle"/>
                    <DoubleProperty name="fieldOfViewX" title="the total field of view in the horizontal direction" min="]0" quantity="length"/>
                    <IntProperty name="numPixelsX" title="the number of pixels in the horizontal direction" default="250" min="1" max="10000"/>
                    <DoubleProperty name="centerX" title="the center of the frame in the horizontal direction" displayedIf="Level2" default="0" quantity="length"/>
                    <DoubleProperty name="fieldOfViewY" title="the total field of view in the vertical direction" min="]0" quantity="length"/>
                    <IntProperty name="numPixelsY" title="the number of pixels in the vertical direction" default="250" min="1" max="10000"/>
                    <DoubleProperty name="centerY" title="the center of the frame in the vertical direction" displayedIf="Level2" default="0" quantity="length"/>
                    <IntProperty name="numSampling" title="the oversampling rate in each direction" default="1" min="1" max="9"/>
                </properties>
            </Type>
            <Type name="AllSkyProjectionForm" base="GenericForm" title="all-sky projection at a position inside the model" concrete="true" displayedIf="Level2">
                <properties type="Property">
                    <ItemProperty name="projection" title="the projection used for mapping the sky to a rectangle" default="HammerAitoffProjection" base="AllSkyProjection"/>
                    <IntProperty name="numPixelsY" title="the number of image pixels in the vertical (shortest) direction" default="250" min="25" max="10000"/>
                    <DoubleProperty name="observerX" title="the position of the observer, x component" quantity="length"/>
                    <DoubleProperty name="observerY" title="the position of the observer, y component" quantity="length"/>
                    <DoubleProperty name="observerZ" title="the position of the observer, z component" quantity="length"/>
                    <DoubleProperty name="crossX" title="the position of the crosshair, x component" default="0" quantity="length"/>
                    <DoubleProperty name="crossY" title="the position of the crosshair, y component" default="0" quantity="length"/>
                    <DoubleProperty name="crossZ" title="the position of the crosshair, z component" default="0" quantity="length"/>
                    <DoubleProperty name="upX" title="the upwards direction, x component" default="0" quantity="length"/>
                    <DoubleProperty name="upY" title="the upwards direction, y component" default="0" quantity="length"/>
                    <DoubleProperty name="upZ" title="the upwards direction, z component" default="1" quantity="length"/>
                </properties>
            </Type>
            <Type name="MonteCarloSimulation" base="Simulation" title="a Monte Carlo simulation" concrete="true">
                <properties type="Property">
                    <EnumProperty name="simulationMode" title="the overall simulation mode" insert="simulationModeOligoNoMedium:Oligochromatic,NoMedium;simulationModeOligoExtinctionOnly:Oligochromatic,ExtinctionOnly;simulationModeNoMedium:Panchromatic,NoMedium;simulationModeExtinctionOnly:Panchromatic,ExtinctionOnly;simulationModeLyaExtinctionOnly:Lya,Panchromatic,ExtinctionOnly;simulationModeDustEmission:Panchromatic,DustEmission,Emission,RadiationField;simulationModeGasEmission:Panchromatic,GasEmission,Emission,RadiationField;simulationModeDustAndGasEmission:Panchromatic,DustEmission,GasEmission,Emission,RadiationField" default="ExtinctionOnly">
                        <enumValues type="EnumValue">
                            <EnumValue name="OligoNoMedium" title="No medium - oligochromatic regime (a few discrete wavelengths)"/>
                            <EnumValue name="OligoExtinctionOnly" title="Extinction only - oligochromatic regime (a few discrete wavelengths)"/>
                            <EnumValue name="NoMedium" title="No medium (primary sources only)"/>
                            <EnumValue name="ExtinctionOnly" title="Extinction only (no secondary emission)"/>
                            <EnumValue name="LyaExtinctionOnly" title="Extinction only with Lyman-alpha line transfer"/>
                            <EnumValue name="DustEmission" title="With secondary emission from dust"/>
                            <EnumValue name="GasEmission" title="With secondary emission from gas"/>
                            <EnumValue name="DustAndGasEmission" title="With secondary emission from dust and gas"/>
                        </enumValues>
                    </EnumProperty>
                    <BoolProperty name="iteratePrimaryEmission" title="iterate over primary emission for self-consistent calculation" relevantIf="simulationModeExtinctionOnly|Emission" displayedIf="Level3" insert="(simulationModeExtinctionOnly|Emission)&amp;iteratePrimaryEmission:IteratePrimary,RadiationField" default="false"/>
                    <BoolProperty name="iterateSecondaryEmission" title="iterate over secondary emission for self-consistent calculation" relevantIf="Emission" displayedIf="Level2" insert="Emission&amp;iterateSecondaryEmission:IterateSecondary" default="false"/>
                    <DoubleProperty name="numPackets" title="the default number of photon packets launched per simulation segment" default="1e6" min="[0" max="1e19]"/>
                    <ItemProperty name="cosmology" title="the cosmology parameters" displayedIf="Level2" default="LocalUniverseCosmology" base="Cosmology"/>
                    <ItemProperty name="sourceSystem" title="the source system" default="SourceSystem" base="SourceSystem"/>
                    <ItemProperty name="mediumSystem" title="the medium system" requiredIf="!NoMedium" default="!NoMedium:MediumSystem;" base="MediumSystem"/>
                    <ItemProperty name="instrumentSystem" title="the instrument system" default="InstrumentSystem" base="InstrumentSystem"/>
                    <ItemProperty name="probeSystem" title="the probe system" default="ProbeSystem" base="ProbeSystem"/>
                </properties>
            </Type>
        </types>
        <quantities type="Quantity">
            <Quantity name="acceleration">
                <units type="Unit">
                    <Unit name="cm/s2" factor="0.01"/>
                    <Unit name="km/s2" factor="1000"/>
                    <Unit name="m/s2" factor="1"/>
                    <Unit name="mm/s2" factor="0.001"/>
                </units>
            </Quantity>
            <Quantity name="angle">
                <units type="Unit">
                    <Unit name="arcsec" factor="4.848136811e-6"/>
                    <Unit name="deg" factor="0.01745329252"/>
                    <Unit name="rad" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="bolluminosity">
                <units type="Unit">
                    <Unit name="J/s" factor="1"/>
                    <Unit name="Lsun" factor="3.839e26"/>
                    <Unit name="W" factor="1"/>
                    <Unit name="erg/s" factor="1e-7"/>
                </units>
            </Quantity>
            <Quantity name="bolluminositysurfacedensity">
                <units type="Unit">
                    <Unit name="Lsun/AU2" factor="17154.07428"/>
                    <Unit name="Lsun/pc2" factor="4.031967494e-7"/>
                    <Unit name="W/m2" factor="1"/>
                    <Unit name="erg/s/cm2" factor="0.001"/>
                </units>
            </Quantity>
            <Quantity name="bolluminosityvolumedensity">
                <units type="Unit">
                    <Unit name="Lsun/AU3" factor="1.146679038e-7"/>
                    <Unit name="Lsun/pc3" factor="1.306671676e-23"/>
                    <Unit name="W/m3" factor="1"/>
                    <Unit name="erg/s/cm3" factor="0.1"/>
                </units>
            </Quantity>
            <Quantity name="bulkmass">
                <units type="Unit">
                    <Unit name="g" factor="0.001"/>
                    <Unit name="kg" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="bulkmassdensity">
                <units type="Unit">
                    <Unit name="g/cm3" factor="1000"/>
                    <Unit name="kg/m3" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="collisionalrate">
                <units type="Unit">
                    <Unit name="cm3/s" factor="1e-6"/>
                    <Unit name="m3/s" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="dimensionless">
                <units type="Unit">
                    <Unit name="1" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="distance">
                <units type="Unit">
                    <Unit name="AU" factor="1.49597871e11"/>
                    <Unit name="Mpc" factor="3.08567758e22"/>
                    <Unit name="cm" factor="0.01"/>
                    <Unit name="km" factor="1000"/>
                    <Unit name="kpc" factor="3.08567758e19"/>
                    <Unit name="m" factor="1"/>
                    <Unit name="mm" factor="0.001"/>
                    <Unit name="pc" factor="3.08567758e16"/>
                </units>
            </Quantity>
            <Quantity name="energy">
                <units type="Unit">
                    <Unit name="1/cm" factor="1.986445683e-23"/>
                    <Unit name="1/m" factor="1.986445683e-25"/>
                    <Unit name="GeV" factor="1.602176634e-10"/>
                    <Unit name="J" factor="1"/>
                    <Unit name="MeV" factor="1.602176634e-13"/>
                    <Unit name="TeV" factor="1.602176634e-7"/>
                    <Unit name="eV" factor="1.602176634e-19"/>
                    <Unit name="erg" factor="1e-7"/>
                    <Unit name="keV" factor="1.602176634e-16"/>
                    <Unit name="meV" factor="1.602176634e-22"/>
                </units>
            </Quantity>
            <Quantity name="energybolluminosity">
                <units type="Unit">
                    <Unit name="W" factor="1"/>
                    <Unit name="erg/s" factor="1e-7"/>
                </units>
            </Quantity>
            <Quantity name="energyfluxdensity">
                <units type="Unit">
                    <Unit name="/s/J/m2" factor="1"/>
                    <Unit name="/s/cm2/keV" factor="6.241509074e19"/>
                    <Unit name="/s/keV/cm2" factor="6.241509074e19"/>
                    <Unit name="/s/m2/J" factor="1"/>
                    <Unit name="1/s/J/m2" factor="1"/>
                    <Unit name="1/s/cm2/keV" factor="6.241509074e19"/>
                    <Unit name="1/s/keV/cm2" factor="6.241509074e19"/>
                    <Unit name="1/s/m2/J" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="energymeanintensity">
                <units type="Unit">
                    <Unit name="/s/J/m2/arcsec2" factor="4.25451703e10"/>
                    <Unit name="/s/J/m2/sr" factor="1"/>
                    <Unit name="/s/cm2/keV/arcsec2" factor="2.655460665e30"/>
                    <Unit name="/s/cm2/keV/sr" factor="6.241509074e19"/>
                    <Unit name="/s/keV/cm2/arcsec2" factor="2.655460665e30"/>
                    <Unit name="/s/keV/cm2/sr" factor="6.241509074e19"/>
                    <Unit name="/s/m2/J/arcsec2" factor="4.25451703e10"/>
                    <Unit name="/s/m2/J/sr" factor="1"/>
                    <Unit name="1/s/J/m2/arcsec2" factor="4.25451703e10"/>
                    <Unit name="1/s/J/m2/sr" factor="1"/>
                    <Unit name="1/s/cm2/keV/arcsec2" factor="2.655460665e30"/>
                    <Unit name="1/s/cm2/keV/sr" factor="6.241509074e19"/>
                    <Unit name="1/s/keV/cm2/arcsec2" factor="2.655460665e30"/>
                    <Unit name="1/s/keV/cm2/sr" factor="6.241509074e19"/>
                    <Unit name="1/s/m2/J/arcsec2" factor="4.25451703e10"/>
                    <Unit name="1/s/m2/J/sr" factor="1"/>
                </units>
            </Quantity>
            <Quantity name="energymonluminosity">
                <units type="Unit">
                    <Unit name="/s/J" factor="1"/>
                    <Unit name="/s/eV" factor="6.241509074e18"/>
                    <Unit name="/s/keV" factor="6.241509074e15"/>
                    <Unit name="1/s/J" factor="1"/>
                    <Unit name="1/s/eV" factor="6.241509074e18"/>
                    <Unit name="1/s/keV" factor="6.241509074e15"/>
                </units>
            </Quantity>
            <Quantity name="energymonluminosityvolumedensity">
                <units type="Unit">
                    <Unit name="/s/J/m3" factor="1"/>
                    <Unit name="/s/eV/m3" factor="6.241509074e18"/>
                    <Unit name="/s/keV/AU3" factor="1.86428956e-18"/>
                    <Unit name="/s/keV/m3" factor="6.241509074e15"/>
                    <Unit name="/s/keV/pc3" factor="2.12440821e-34"/>
                    <Unit name="1/s/J/m3" factor="1"/>
                    <Unit name="1/s/eV/m3" factor="6.241509074e18"/>
                    <Unit name="1/s/keV/AU3" factor="1.86428956e-18"/>
                    <Unit name="1/s/keV/m3" factor="6.241509074e15"/>
                    <Unit name="1/s/keV/pc3" factor="2.12440821e-34"/>
                </units>
            </Quantity>
